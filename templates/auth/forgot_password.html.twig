{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié — EnMémoire.com{% endblock %}
{% block body_class %}auth-page{% endblock %}
{% block stylesheets %}<link rel="stylesheet" href="{{ asset('css/auth.css') }}">{% endblock %}
{% block body %}
<div class="auth-wrapper auth-wrapper--centered">
  <div class="auth-panel auth-panel--narrow">
    <div class="auth-panel__inner">
      <a href="{{ path('app_home') }}" class="auth-logo">🕯️ <span>En<strong>Mémoire</strong>.com</span></a>
      <div class="auth-otp-icon"><i class="bi bi-key" style="color:var(--em-gold);"></i></div>
      <h1 class="auth-title">Mot de passe oublié ?</h1>

      {% if sent %}
        <div class="auth-alert auth-alert--success">
          <i class="bi bi-check-circle"></i>
          Si un compte existe avec cette adresse, un code de réinitialisation a été envoyé.
        </div>
        <a href="{{ path('app_reset_password') }}" class="auth-submit d-flex mt-3">
          <i class="bi bi-arrow-right"></i> Saisir mon code de réinitialisation
        </a>
      {% else %}
        {% if error %}<div class="auth-alert auth-alert--error"><i class="bi bi-exclamation-circle"></i> {{ error }}</div>{% endif %}
        <p class="auth-subtitle">Entrez votre email, nous vous enverrons un code de réinitialisation.</p>
        <form method="POST" class="auth-form" data-disable-on-submit>
          <input type="hidden" name="_token" value="{{ csrf_token('forgot_pw') }}">
          <div class="auth-field">
            <label class="auth-label">Adresse email</label>
            <div class="auth-input-wrap">
              <i class="bi bi-envelope auth-input-icon"></i>
              <input type="email" name="email" class="auth-input" required autocomplete="email" autofocus placeholder="votre@email.com">
            </div>
          </div>
          <button type="submit" class="auth-submit"><i class="bi bi-send"></i> Envoyer le code</button>
        </form>
      {% endif %}

      <p class="auth-switch mt-3"><a href="{{ path('app_login') }}"><i class="bi bi-arrow-left"></i> Retour à la connexion</a></p>
    </div>
  </div>
</div>
{% endblock %}
