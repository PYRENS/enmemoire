{% extends 'base.html.twig' %}
{% block title %}Réinitialiser le mot de passe — EnMémoire.com{% endblock %}
{% block body_class %}auth-page{% endblock %}
{% block stylesheets %}<link rel="stylesheet" href="{{ asset('css/auth.css') }}">{% endblock %}
{% block body %}
<div class="auth-wrapper auth-wrapper--centered">
  <div class="auth-panel auth-panel--narrow">
    <div class="auth-panel__inner">
      <a href="{{ path('app_home') }}" class="auth-logo">🕯️ <span>En<strong>Mémoire</strong>.com</span></a>
      <div class="auth-otp-icon"><i class="bi bi-shield-lock" style="color:var(--em-gold);"></i></div>
      <h1 class="auth-title">Nouveau mot de passe</h1>

      {% if error %}<div class="auth-alert auth-alert--error"><i class="bi bi-exclamation-circle"></i> {{ error }}</div>{% endif %}

      {% if not verified %}
        {# Étape 1 : saisie du code OTP #}
        <p class="auth-subtitle">Entrez le code reçu par email.</p>
        <form method="POST" class="auth-form" id="otp-form">
          <input type="hidden" name="_token" value="{{ csrf_token('reset_pw') }}">
          <input type="hidden" name="action" value="verify">
          <div class="auth-otp-inputs" id="otp-boxes">
            {% for i in 1..6 %}
              <input type="text" name="digit[]" maxlength="1" class="auth-otp-digit" inputmode="numeric" pattern="[0-9]" required>
            {% endfor %}
          </div>
          <button type="submit" class="auth-submit"><i class="bi bi-check-lg"></i> Vérifier</button>
        </form>
      {% else %}
        {# Étape 2 : nouveau mot de passe #}
        <p class="auth-subtitle">Code vérifié ✅ — Choisissez votre nouveau mot de passe.</p>
        <form method="POST" class="auth-form" data-disable-on-submit>
          <input type="hidden" name="_token" value="{{ csrf_token('reset_pw') }}">
          <input type="hidden" name="action" value="reset">
          <div class="auth-field">
            <label class="auth-label">Nouveau mot de passe</label>
            <div class="auth-input-wrap">
              <i class="bi bi-lock auth-input-icon"></i>
              <input type="password" name="password" class="auth-input" required minlength="8" placeholder="••••••••">
              <button type="button" class="auth-toggle-pw"><i class="bi bi-eye"></i></button>
            </div>
            <div class="auth-pw-strength"><div class="auth-pw-strength__bar"></div></div>
          </div>
          <div class="auth-field">
            <label class="auth-label">Confirmer</label>
            <div class="auth-input-wrap">
              <i class="bi bi-lock-fill auth-input-icon"></i>
              <input type="password" name="password_confirm" class="auth-input" required placeholder="••••••••">
            </div>
          </div>
          <button type="submit" class="auth-submit"><i class="bi bi-check-circle"></i> Changer le mot de passe</button>
        </form>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
{% block javascripts %}<script src="{{ asset('js/auth.js') }}"></script>{% endblock %}
