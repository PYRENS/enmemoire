{% extends 'admin/layout.html.twig' %}
{% block title %}{{ user.fullName }} — Admin{% endblock %}

{% block admin_content %}
<div class="admin-page-header">
  <h1><i class="bi bi-person me-2"></i>{{ user.fullName }}</h1>
  <a href="{{ path('app_admin_users') }}" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Retour
  </a>
</div>

<div class="row g-4">
  {# Infos utilisateur #}
  <div class="col-lg-4">
    <div class="admin-form-card">
      <div class="text-center mb-3">
        {% if user.avatarUrl and user.avatarUrl starts with 'http' %}
          {# Cloudinary ou URL absolue #}
          <img src="{{ user.avatarUrl }}" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--em-gold);">
        {% elseif user.avatarUrl %}
          {# Fichier local #}
          <img src="{{ asset(user.avatarUrl) }}" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid var(--em-gold);"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
          <div style="display:none;width:80px;height:80px;border-radius:50%;background:var(--em-navy);color:white;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;margin:0 auto;border:3px solid var(--em-gold);">
            {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
          </div>
        {% else %}
          {# Initiales #}
          <div style="width:80px;height:80px;border-radius:50%;background:var(--em-navy);color:white;display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;margin:0 auto;border:3px solid var(--em-gold);">
            {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
          </div>
        {% endif %}
        <div class="mt-2 fw-700 fs-5">{{ user.fullName }}</div>
        <div class="text-muted small">{{ user.email }}</div>
      </div>

      <table class="w-100" style="font-size:.875rem;">
        <tr><td class="text-muted py-1">ID</td><td class="fw-600">{{ user.id }}</td></tr>
        <tr><td class="text-muted py-1">Téléphone</td><td>{{ user.phoneWhatsapp ?? '—' }}</td></tr>
        <tr><td class="text-muted py-1">Locale</td><td>{{ user.locale|upper }}</td></tr>
        <tr><td class="text-muted py-1">Email vérifié</td><td>{{ user.isEmailVerified() ? '✅' : '❌' }}</td></tr>
        <tr><td class="text-muted py-1">Inscrit le</td><td>{{ user.createdAt|date('d/m/Y') }}</td></tr>
        <tr><td class="text-muted py-1">Dernière connexion</td><td>{{ user.lastLoginAt ? user.lastLoginAt|date('d/m/Y') : '—' }}</td></tr>
      </table>
    </div>

    {# Changer statut #}
    <div class="admin-form-card mt-3">
      <h3 style="font-size:.875rem;font-weight:700;margin-bottom:1rem;">Statut du compte</h3>
      <div class="d-flex gap-2 flex-wrap">
        <button onclick="adminSetStatus('{{ path('app_admin_user_status', {id: user.id}) }}', 'active', '')"
                class="btn btn-sm {{ user.status == 'active' ? 'btn-success' : 'btn-outline-success' }}"
                style="color:{{ user.status == 'active' ? 'white' : '' }}">
          Activer
        </button>
        <button onclick="adminSetStatus('{{ path('app_admin_user_status', {id: user.id}) }}', 'suspended', '')"
                class="btn btn-sm {{ user.status == 'suspended' ? 'btn-warning' : 'btn-outline-warning' }}"
                style="color:#1a1a1a !important;">
          Suspendre
        </button>
        <button onclick="adminSetStatus('{{ path('app_admin_user_status', {id: user.id}) }}', 'disabled', '')"
                class="btn btn-sm {{ user.status == 'disabled' ? 'btn-danger' : 'btn-outline-danger' }}"
                style="color:{{ user.status == 'disabled' ? 'white' : '' }} !important;">
          Désactiver
        </button>
      </div>
    </div>

    {# Changer rôle (Super Admin only) #}
    {% if is_granted('ROLE_SUPER_ADMIN') %}
    <div class="admin-form-card mt-3">
      <h3 style="font-size:.875rem;font-weight:700;margin-bottom:1rem;">Rôle</h3>
      <select id="roleSelect" class="form-control form-control-sm mb-2">
        {% for r in ['ROLE_USER', 'ROLE_MAKER', 'ROLE_MANAGER', 'ROLE_ADMIN', 'ROLE_SUPER_ADMIN'] %}
          <option value="{{ r }}" {{ user.role == r ? 'selected' : '' }}>{{ r|replace({'ROLE_': ''}) }}</option>
        {% endfor %}
      </select>
      <button onclick="adminSetRole('{{ path('app_admin_user_role', {id: user.id}) }}', document.getElementById('roleSelect').value, '')"
              class="btn btn-sm btn-primary w-100">Appliquer le rôle</button>
    </div>
    {% endif %}

    {# Reset mot de passe #}
    <div class="admin-form-card mt-3">
      <h3 style="font-size:.875rem;font-weight:700;margin-bottom:1rem;">Reset mot de passe</h3>
      <input type="password" id="newPwd" class="form-control form-control-sm mb-2" placeholder="Nouveau mot de passe (min 8 car.)">
      <button onclick="resetPwd()" class="btn btn-sm btn-outline-danger w-100">
        <i class="bi bi-key me-1"></i>Réinitialiser
      </button>
    </div>
  </div>

  {# Mémoriaux & Paiements #}
  <div class="col-lg-8">
    {# Mémoriaux #}
    <div class="admin-form-card mb-4">
      <h3 style="font-size:1rem;font-weight:700;margin-bottom:1rem;">
        <i class="bi bi-book me-2"></i>Mémoriaux ({{ user.memorialPages|length }})
      </h3>
      {% if user.memorialPages|length %}
      <table class="admin-table">
        <thead><tr><th>Défunt</th><th>Slug</th><th>Formule</th><th>Statut</th><th>Créé le</th><th>Actions</th></tr></thead>
        <tbody>
          {% for p in user.memorialPages %}
          <tr>
            <td><strong>{{ p.deceasedFullName }}</strong></td>
            <td class="text-muted small">{{ p.slug }}</td>
            <td>{{ p.formula ? p.formula.name : '—' }}</td>
            <td><span class="badge-{{ p.status }}">{{ p.status }}</span></td>
            <td class="text-muted">{{ p.createdAt|date('d/m/Y') }}</td>
            <td>
              <a href="{{ path('app_memorial_show', {slug: p.slug}) }}" target="_blank"
                 class="btn btn-sm btn-outline-primary" title="Voir la page">
                <i class="bi bi-eye"></i>
              </a>
              <a href="{{ path('app_dashboard_memorial', {slug: p.slug}) }}" target="_blank"
                 class="btn btn-sm btn-outline-secondary ms-1" title="Dashboard">
                <i class="bi bi-gear"></i>
              </a>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="text-muted">Aucun mémorial créé.</p>
      {% endif %}
    </div>

    {# Paiements #}
    <div class="admin-form-card">
      <h3 style="font-size:1rem;font-weight:700;margin-bottom:1rem;">
        <i class="bi bi-credit-card me-2"></i>Paiements ({{ payments|length }})
      </h3>
      {% if payments|length %}
      <table class="admin-table">
        <thead><tr><th>Montant</th><th>Provider</th><th>Statut</th><th>Date</th></tr></thead>
        <tbody>
          {% for p in payments %}
          <tr>
            <td><strong>{{ p.amount }} {{ p.currency }}</strong></td>
            <td>{{ p.provider }}</td>
            <td><span class="badge-{{ p.status }}">{{ p.status }}</span></td>
            <td class="text-muted">{{ p.createdAt|date('d/m/Y H:i') }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="text-muted">Aucun paiement.</p>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
async function resetPwd() {
  const pwd = document.getElementById('newPwd').value;
  if (pwd.length < 8) { alert('Minimum 8 caractères'); return; }
  if (!confirm('Réinitialiser le mot de passe de {{ user.fullName }} ?')) return;
  const fd = new FormData();
  fd.append('password', pwd);
  const res  = await fetch('{{ path('app_admin_user_reset_password', {id: user.id}) }}', {
    method: 'POST', body: fd, headers: {'X-Requested-With': 'XMLHttpRequest'}
  });
  const data = await res.json();
  if (data.success) { alert('Mot de passe réinitialisé.'); document.getElementById('newPwd').value = ''; }
  else alert(data.error || 'Erreur');
}
</script>
{% endblock %}
