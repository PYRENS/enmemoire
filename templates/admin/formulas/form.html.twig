{% extends 'admin/layout.html.twig' %}
{% block title %}{{ isNew ? 'Nouvelle formule' : 'Modifier ' ~ formula.name }} — Admin{% endblock %}

{% block admin_content %}
<div class="admin-page-header">
  <h1><i class="bi bi-box-seam me-2"></i>{{ isNew ? 'Nouvelle formule' : 'Modifier : ' ~ formula.name }}</h1>
  <a href="{{ path('app_admin_formulas') }}" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Retour
  </a>
</div>

<div class="admin-form-card">
  <form method="POST">
    <div class="admin-form-section">
      <h3>Informations générales</h3>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-600">Nom <span class="text-danger">*</span></label>
          <input type="text" name="name" class="form-control" value="{{ formula.name }}" required>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-600">Slug <span class="text-danger">*</span></label>
          <input type="text" name="slug" class="form-control" value="{{ formula.slug }}" required
                 placeholder="ex: essentielle">
        </div>
        <div class="col-12">
          <label class="form-label fw-600">Description</label>
          <textarea name="description" class="form-control" rows="3">{{ formula.description }}</textarea>
        </div>
      </div>
    </div>

    <div class="admin-form-section">
      <h3>Tarification & durée</h3>
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label fw-600">Prix</label>
          <input type="number" name="price" class="form-control" value="{{ formula.price }}" step="0.01" min="0">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-600">Devise</label>
          <select name="currency" class="form-control">
            <option value="EUR" {{ formula.currency == 'EUR' ? 'selected' : '' }}>EUR (€)</option>
            <option value="USD" {{ formula.currency == 'USD' ? 'selected' : '' }}>USD ($)</option>
            <option value="CDF" {{ formula.currency == 'CDF' ? 'selected' : '' }}>CDF (FC)</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-600">Durée (années)</label>
          <input type="number" name="duration_years" class="form-control"
                 value="{{ formula.durationYears }}" min="1" placeholder="Vide = perpétuel">
          <div class="form-text">Laisser vide pour perpétuel</div>
        </div>
      </div>
    </div>

    <div class="admin-form-section">
      <h3>Limites & fonctionnalités</h3>
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label fw-600">Max événements</label>
          <input type="number" name="max_events" class="form-control" value="{{ formula.maxEvents }}" min="1">
        </div>
        <div class="col-md-3">
          <label class="form-label fw-600">Max médias (Go)</label>
          <input type="number" name="max_media_gb" class="form-control" value="{{ formula.maxMediaGb }}" min="1">
        </div>
        <div class="col-md-3">
          <label class="form-label fw-600">Ordre d'affichage</label>
          <input type="number" name="sort_order" class="form-control" value="{{ formula.sortOrder }}">
        </div>
      </div>

      <div class="row g-3 mt-2">
        {% set options = [
          {name: 'has_live',            label: 'Diffusion live',       checked: formula.isHasLive()},
          {name: 'has_video',           label: 'Vidéos',               checked: formula.isHasVideo()},
          {name: 'has_qr_code',         label: 'QR Code',              checked: formula.isHasQrCode()},
          {name: 'has_premium_themes',  label: 'Thèmes premium',       checked: formula.isHasPremiumThemes()},
          {name: 'has_advanced_stats',  label: 'Stats avancées',       checked: formula.isHasAdvancedStats()},
          {name: 'is_active',           label: 'Formule active',       checked: formula.isActive()},
        ] %}
        {% for opt in options %}
        <div class="col-md-4">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" name="{{ opt.name }}" value="1"
                   id="{{ opt.name }}" {{ opt.checked ? 'checked' : '' }}>
            <label class="form-check-label" for="{{ opt.name }}">{{ opt.label }}</label>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
      <a href="{{ path('app_admin_formulas') }}" class="btn btn-outline-secondary">Annuler</a>
      <button type="submit" class="em-btn em-btn--primary">
        <i class="bi bi-check-lg me-1"></i>{{ isNew ? 'Créer' : 'Enregistrer' }}
      </button>
    </div>
  </form>
</div>
{% endblock %}
