{% extends 'admin/layout.html.twig' %}
{% block title %}Thèmes — Admin{% endblock %}

{% block admin_content %}
<div class="admin-page-header">
  <h1><i class="bi bi-palette me-2"></i>Thèmes</h1>
  <a href="{{ path('app_admin_theme_new') }}" class="em-btn em-btn--primary em-btn--sm">
    <i class="bi bi-plus-lg me-1"></i>Nouveau thème
  </a>
</div>

<div class="admin-form-card p-0">
  <div class="table-responsive">
    <table class="admin-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Aperçu</th>
          <th>Nom / Slug</th>
          <th>Type</th>
          <th>Prix</th>
          <th>Pages</th>
          <th>Statut</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for t in themes %}
        <tr>
          <td class="text-muted">{{ t.sortOrder }}</td>
          <td>
            <div style="width:48px;height:32px;border-radius:6px;background:linear-gradient(135deg,var(--em-navy),var(--em-gold));border:1px solid var(--em-stone);overflow:hidden;">
              {% if t.previewUrl %}
                <img src="{{ t.previewUrl }}" style="width:100%;height:100%;object-fit:cover;">
              {% endif %}
            </div>
          </td>
          <td>
            <strong>{{ t.name }}</strong>
            <div style="font-size:.72rem;color:var(--em-muted);">{{ t.slug }}</div>
          </td>
          <td><span class="badge-{{ t.type }}">{{ t.type }}</span></td>
          <td>
            {% if t.isFree() %}
              <span class="text-success fw-600">Gratuit</span>
            {% else %}
              {{ t.price }} {{ t.currency }}
            {% endif %}
          </td>
          <td>{{ t.memorialPages|length }}</td>
          <td>
            <button onclick="adminToggle('{{ path('app_admin_theme_toggle', {id: t.id}) }}', this)"
                    class="btn btn-sm {{ t.isActive() ? 'btn-success' : 'btn-secondary' }}"
                    title="{{ t.isActive() ? 'Désactiver' : 'Activer' }}">
              <i class="bi bi-{{ t.isActive() ? 'check-circle' : 'pause-circle' }}"></i>
            </button>
          </td>
          <td>
            <a href="{{ path('app_admin_theme_edit', {id: t.id}) }}" class="btn btn-sm btn-outline-primary me-1">
              <i class="bi bi-pencil"></i>
            </a>
            {% if t.memorialPages|length == 0 %}
            <form method="POST" action="{{ path('app_admin_theme_delete', {id: t.id}) }}" class="d-inline"
                  onsubmit="return confirm('Supprimer ce thème ?')">
              <input type="hidden" name="_token" value="{{ csrf_token('theme_delete_' ~ t.id) }}">
              <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
            {% endif %}
          </td>
        </tr>
        {% else %}
        <tr><td colspan="8" class="text-center text-muted py-4">Aucun thème</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endblock %}
