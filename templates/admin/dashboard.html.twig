{% extends 'admin/layout.html.twig' %}
{% block title %}Dashboard Admin — EnMémoire.com{% endblock %}

{% block admin_content %}
<div class="admin-page-header">
  <h1><i class="bi bi-speedometer2 me-2"></i>Dashboard Admin</h1>
  <span class="text-muted small">{{ 'now'|date('d/m/Y à H:i') }}</span>
</div>

{# Stats #}
<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card admin-stat-card--blue">
      <div class="admin-stat-card__value">{{ stats.users }}</div>
      <div class="admin-stat-card__label"><i class="bi bi-people me-1"></i>Utilisateurs</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card">
      <div class="admin-stat-card__value">{{ stats.pages }}</div>
      <div class="admin-stat-card__label"><i class="bi bi-book me-1"></i>Mémoriaux</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card admin-stat-card--green">
      <div class="admin-stat-card__value">{{ stats.revenue|number_format(0, ',', ' ') }} €</div>
      <div class="admin-stat-card__label"><i class="bi bi-currency-euro me-1"></i>Revenus totaux</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="admin-stat-card admin-stat-card--red">
      <div class="admin-stat-card__value">{{ stats.pending }}</div>
      <div class="admin-stat-card__label"><i class="bi bi-hourglass me-1"></i>Paiements en attente</div>
    </div>
  </div>
</div>

<div class="row g-4">
  {# Derniers paiements #}
  <div class="col-lg-8">
    <div class="admin-form-card">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 style="margin:0;font-size:1rem;font-weight:700;color:var(--em-navy);">
          <i class="bi bi-credit-card me-2"></i>Derniers paiements
        </h3>
        <a href="{{ path('app_admin_payments') }}" class="btn btn-sm btn-outline-secondary">Voir tout</a>
      </div>
      <div class="table-responsive">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Utilisateur</th>
              <th>Montant</th>
              <th>Provider</th>
              <th>Statut</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            {% for p in recentPayments %}
            <tr>
              <td>
                <a href="{{ path('app_admin_user_show', {id: p.user.id}) }}" class="text-decoration-none">
                  {{ p.user.fullName }}
                </a>
              </td>
              <td><strong>{{ p.amount }} {{ p.currency }}</strong></td>
              <td><span class="badge bg-light text-dark">{{ p.provider }}</span></td>
              <td><span class="badge-{{ p.status }}">{{ p.status }}</span></td>
              <td class="text-muted">{{ p.createdAt|date('d/m/Y') }}</td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="text-center text-muted py-3">Aucun paiement</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  {# Derniers utilisateurs #}
  <div class="col-lg-4">
    <div class="admin-form-card">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 style="margin:0;font-size:1rem;font-weight:700;color:var(--em-navy);">
          <i class="bi bi-person-plus me-2"></i>Nouveaux membres
        </h3>
        <a href="{{ path('app_admin_users') }}" class="btn btn-sm btn-outline-secondary">Voir tout</a>
      </div>
      {% for u in recentUsers %}
      <div class="d-flex align-items-center gap-2 mb-2 pb-2 border-bottom">
        <div style="width:36px;height:36px;border-radius:50%;background:var(--em-navy);color:white;display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;flex-shrink:0;">
          {{ u.firstName|first|upper }}{{ u.lastName|first|upper }}
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:.875rem;font-weight:600;color:var(--em-navy);">{{ u.fullName }}</div>
          <div style="font-size:.72rem;color:var(--em-muted);">{{ u.createdAt|date('d/m/Y') }}</div>
        </div>
        <span class="badge-{{ u.status }}">{{ u.status }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</div>
{% endblock %}
