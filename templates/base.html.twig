<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}" data-theme="{{ memorial_theme|default('classic-white') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{% block meta_description %}EnMémoire.com — Plateforme Mémorielle Numérique{% endblock %}">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <meta property="og:title" content="{% block og_title %}EnMémoire.com{% endblock %}">
    <meta property="og:description" content="{% block og_description %}Préservez et partagez la mémoire de vos proches{% endblock %}">
    <meta property="og:type" content="website">

    <title>{% block title %}EnMémoire.com{% endblock %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    <link rel="stylesheet" href="{{ asset('css/themes/theme-base.css') }}">
    {% if memorial_theme is defined and memorial_theme %}
        <link rel="stylesheet" href="{{ asset('css/themes/theme-' ~ memorial_theme ~ '.css') }}">
    {% endif %}
    {% block stylesheets %}{% endblock %}
    {# Injection forcée des variables du thème — écrase app.css #}
    {% if memorial_theme is defined and memorial_theme and memorial_theme != 'classic-white' %}
    <style id="theme-vars">
    {% if memorial_theme == 'nature-green' %}
      :root { --em-gold:#4A8C5C; --em-navy:#1E4D2B; --em-bg:#F4F8F2; --em-cream:#EBF3E8; --em-stone:rgba(30,77,43,.15); --em-muted:#5A7A5C; --em-charcoal:#3E5E40; }
      .memorial-hero { background: linear-gradient(160deg,#0D2E14 0%,#1E4D2B 50%,#2D7A45 100%) !important; }
    {% elseif memorial_theme == 'ocean-blue' %}
      :root { --em-gold:#1E6FA8; --em-navy:#0D3159; --em-bg:#F0F5FA; --em-cream:#E4EEF7; --em-stone:rgba(13,49,89,.12); --em-muted:#4A6785; --em-charcoal:#2A4060; }
      .memorial-hero { background: linear-gradient(160deg,#081E3A 0%,#0D3159 50%,#1E5F8C 100%) !important; }
    {% elseif memorial_theme == 'sunset-warm' %}
      :root { --em-gold:#D4622A; --em-navy:#6B2F0A; --em-bg:#FDF6EE; --em-cream:#FAF0E4; --em-stone:rgba(107,47,10,.12); --em-muted:#8C5A38; --em-charcoal:#5C3018; }
      .memorial-hero { background: linear-gradient(160deg,#3D1A05 0%,#7C2D12 40%,#C2410C 70%,#EA580C 100%) !important; }
    {% elseif memorial_theme == 'african-gold' %}
      :root { --em-gold:#D4A017; --em-navy:#1C1008; --em-bg:#1C1008; --em-cream:#241408; --em-stone:rgba(212,160,23,.20); --em-muted:#A8906C; --em-charcoal:#C8A878; }
      body, .em-main { background:#1C1008 !important; color:#F0E0C8 !important; }
      .memorial-hero { background: linear-gradient(160deg,#0A0600 0%,#1C1008 50%,#2C1A0A 100%) !important; }
      .memorial-name { color:#F5D89A !important; }
      .memorial-tabs-wrap, .memorial-content { background:#1C1008 !important; }
      .memorial-form-card, .memorial-condolence, .memorial-guestbook__entry { background:#2C1A0A !important; color:#F0E0C8 !important; }
      .memorial-footer { background:#241408 !important; }
    {% elseif memorial_theme == 'night-stars' %}
      :root { --em-gold:#C9A84C; --em-navy:#0E1628; --em-bg:#0E1628; --em-cream:#131D35; --em-stone:rgba(255,255,255,.08); --em-muted:#7A90B0; --em-charcoal:#A0B0C8; }
      body, .em-main { background:#0E1628 !important; color:#D4DCE8 !important; }
      .memorial-hero { background: linear-gradient(160deg,#060C1A 0%,#0E1628 60%,#131D35 100%) !important; }
      .memorial-name { color:#E8EEF8 !important; }
      .memorial-tabs-wrap, .memorial-content { background:#0E1628 !important; }
      .memorial-form-card, .memorial-condolence, .memorial-guestbook__entry { background:#1A2540 !important; color:#D4DCE8 !important; }
      .memorial-footer { background:#131D35 !important; }
    {% elseif memorial_theme == 'cherry-blossom' %}
      :root { --em-gold:#F9A8D4; --em-navy:#500724; --em-bg:#FFF1F2; --em-cream:#FFE4E6; --em-stone:rgba(190,24,93,.12); --em-muted:#BE185D; --em-charcoal:#9D174D; }
      .memorial-hero { background: linear-gradient(160deg,#500724 0%,#9D174D 50%,#BE185D 100%) !important; }
    {% elseif memorial_theme == 'golden-light' %}
      :root { --em-gold:#F59E0B; --em-navy:#451A03; --em-bg:#FFFBEB; --em-cream:#FEF3C7; --em-stone:rgba(180,83,9,.14); --em-muted:#B45309; --em-charcoal:#92400E; }
      .memorial-hero { background: linear-gradient(160deg,#451A03 0%,#92400E 40%,#B45309 70%,#D97706 100%) !important; }
    {% elseif memorial_theme == 'royal-purple' %}
      :root { --em-gold:#C4B5FD; --em-navy:#1E1B4B; --em-bg:#FAF5FF; --em-cream:#F3E8FF; --em-stone:rgba(107,33,168,.15); --em-muted:#6D28D9; --em-charcoal:#4C1D95; }
      .memorial-hero { background: linear-gradient(160deg,#1E1B4B 0%,#4C1D95 50%,#6B21A8 100%) !important; }
    {% elseif memorial_theme == 'eternal-black' %}
      :root { --em-gold:#D4AF37; --em-navy:#0A0A0A; --em-bg:#111111; --em-cream:#1A1A1A; --em-stone:#2A2A2A; --em-muted:#888888; --em-charcoal:#AAAAAA; }
      body, .em-main { background:#111111 !important; color:#E5E5E5 !important; }
      .memorial-hero { background: linear-gradient(160deg,#000 0%,#0D0D0D 50%,#1A1A1A 100%) !important; }
      .memorial-tabs-wrap, .memorial-content { background:#111111 !important; }
      .memorial-form-card, .memorial-condolence, .memorial-guestbook__entry { background:#1A1A1A !important; color:#E5E5E5 !important; }
      .memorial-footer { background:#0D0D0D !important; }
    {% elseif memorial_theme == 'sahara-sand' %}
      :root { --em-gold:#C8860A; --em-navy:#5C3D11; --em-bg:#FAF3E0; --em-cream:#F5E6C8; --em-stone:rgba(92,61,17,.12); --em-muted:#8B6914; --em-charcoal:#6B4F1A; }
      .memorial-hero { background: linear-gradient(160deg,#3D2408 0%,#7A4A1A 40%,#C8860A 100%) !important; }
    {% elseif memorial_theme == 'rose-eternal' %}
      :root { --em-gold:#E11D48; --em-navy:#881337; --em-bg:#FFF5F7; --em-cream:#FFE4E6; --em-stone:rgba(225,29,72,.12); --em-muted:#BE123C; --em-charcoal:#9F1239; }
      .memorial-hero { background: linear-gradient(160deg,#4C0519 0%,#881337 50%,#BE123C 100%) !important; }
    {% elseif memorial_theme == 'aurora-sky' %}
      :root { --em-gold:#34D399; --em-navy:#0F172A; --em-bg:#0F172A; --em-cream:#1E293B; --em-stone:rgba(52,211,153,.12); --em-muted:#64748B; --em-charcoal:#94A3B8; }
      body, .em-main { background:#0F172A !important; color:#E2E8F0 !important; }
      .memorial-hero { background: linear-gradient(160deg,#0F172A 0%,#1E3A5F 40%,#0F4C3A 100%) !important; }
      .memorial-tabs-wrap, .memorial-content { background:#0F172A !important; }
      .memorial-name { color:#F0FDF4 !important; }
      .memorial-form-card, .memorial-condolence, .memorial-guestbook__entry { background:#1E293B !important; color:#E2E8F0 !important; }
      .memorial-footer { background:#1E293B !important; }
    {% elseif memorial_theme == 'white-marble' %}
      :root { --em-gold:#8B7355; --em-navy:#2C2417; --em-bg:#FAFAF8; --em-cream:#F5F2EE; --em-stone:rgba(44,36,23,.10); --em-muted:#7A6E5F; --em-charcoal:#5C5248; }
      .memorial-hero { background: linear-gradient(160deg,#1A1510 0%,#2C2417 50%,#4A3C28 100%) !important; }
    {% elseif memorial_theme == 'congo-green' %}
      :root { --em-gold:#F59E0B; --em-navy:#14532D; --em-bg:#F0F7EE; --em-cream:#DCFCE7; --em-stone:rgba(20,83,45,.12); --em-muted:#166534; --em-charcoal:#15803D; }
      .memorial-hero { background: linear-gradient(160deg,#052E16 0%,#14532D 50%,#166534 100%) !important; }
    {% elseif memorial_theme == 'kinshasa-night' %}
      :root { --em-gold:#F97316; --em-navy:#0D0D1A; --em-bg:#0D0D1A; --em-cream:#161625; --em-stone:rgba(249,115,22,.15); --em-muted:#6B7280; --em-charcoal:#9CA3AF; }
      body, .em-main { background:#0D0D1A !important; color:#E5E7EB !important; }
      .memorial-hero { background: linear-gradient(180deg,#0D0D1A 0%,#1A0A00 60%,#2D1200 100%) !important; }
      .memorial-tabs-wrap, .memorial-content { background:#0D0D1A !important; }
      .memorial-name { color:#FFF7ED !important; }
      .memorial-form-card, .memorial-condolence, .memorial-guestbook__entry { background:#161625 !important; color:#E5E7EB !important; }
      .memorial-footer { background:#161625 !important; }
    {% elseif memorial_theme == 'callas-noir' %}
      :root { --em-gold:#D4A843; --em-navy:#0A0A0A; --em-bg:#111111; --em-cream:#1A1A1A; --em-stone:rgba(212,168,67,.15); --em-muted:#8A8A8A; --em-charcoal:#C0C0C0; }
      body, .em-main { background:#111111 !important; color:#E8E8E8 !important; }
      .memorial-hero { background: radial-gradient(ellipse at top,#1C1C1C 0%,#0A0A0A 70%) !important; }
      .memorial-tabs-wrap, .memorial-content { background:#111111 !important; }
      .memorial-name { color:#FFFFFF !important; font-style:italic !important; text-shadow:0 2px 20px rgba(212,168,67,.3) !important; }
      .memorial-form-card, .memorial-condolence, .memorial-guestbook__entry { background:#1A1A1A !important; color:#E8E8E8 !important; }
      .memorial-footer { background:#0A0A0A !important; }
    {% endif %}
    </style>
    {% endif %}
</head>
<body class="{% block body_class %}{% endblock %} {{ app.user ? 'user-logged' : 'user-guest' }}">

<header class="em-header" id="site-header">
    <nav class="navbar navbar-expand-lg em-navbar">
        <div class="container-xl">

            {# Logo #}
            <a class="navbar-brand em-logo" href="{{ path('app_home') }}">
                <span class="em-logo__flame" aria-hidden="true">
                    <svg width="22" height="28" viewBox="0 0 26 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13 2C13 2 4 9 4 18C4 23.523 8.477 28 14 28C19.523 28 24 23.523 24 18C24 12 18 8 17 4C17 4 16 10 12 12C12 12 14 7 13 2Z" fill="currentColor" opacity="0.9"/>
                        <path d="M13 16C13 16 10 19 10 22C10 24.209 11.791 26 14 26C16.209 26 18 24.209 18 22C18 19 15 17 14 14C14 14 13.5 17 13 16Z" fill="white" opacity="0.6"/>
                    </svg>
                </span>
                <span class="em-logo__text">En<strong>Mémoire</strong></span>
            </a>

            {# Burger mobile #}
            <button class="navbar-toggler em-toggler" style="border:0!important;box-shadow:none!important;outline:0!important;" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">

                {# Liens gauche #}
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}"
                           href="{{ path('app_home') }}">
                            <i class="bi bi-house-door"></i> {{ 'nav.home'|trans }}
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_memorial_search' %}active{% endif %}"
                           href="{{ path('app_memorial_search') }}">
                            <i class="bi bi-search"></i> {{ 'nav.search'|trans }}
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_obituaries' %}active{% endif %}"
                           href="{{ path('app_obituaries') }}">
                            <i class="bi bi-newspaper"></i> {{ 'nav.obituaries'|trans }}
                        </a>
                    </li>
                    {% if app.user %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_gadget_shop') }}">
                            <i class="bi bi-shop"></i> {{ 'nav.shop'|trans }}
                        </a>
                    </li>
                    {% endif %}
                </ul>

                {# Liens droite #}
                <ul class="navbar-nav ms-auto align-items-center gap-1">

                    {# ── Sélecteur de langue ──────────────────────────────
                       Deux nav-link simples côte à côte.
                       <img> SVG direct depuis vos fichiers locaux.
                       Aucun wrapper, aucun CSS custom, pas de dropdown.
                    ───────────────────────────────────────────────────── #}
                    <li class="nav-item">
                        <a class="nav-link py-1 px-2 {% if app.request.locale != 'en' %}fw-bold text-dark{% endif %}"
                           href="?_locale=fr" title="Français">
                            <img src="{{ asset('bibliotheques/flag-icons/flags/4x3/fr.svg') }}"
                                 width="20" height="14" alt="FR"
                                 style="border-radius:2px;box-shadow:0 0 0 1px rgba(0,0,0,.15);vertical-align:middle;">
                            <span style="font-size:.75rem;vertical-align:middle;"> FR</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link py-1 px-2 {% if app.request.locale == 'en' %}fw-bold text-dark{% endif %}"
                           href="?_locale=en" title="English">
                            <img src="{{ asset('bibliotheques/flag-icons/flags/4x3/gb.svg') }}"
                                 width="20" height="14" alt="EN"
                                 style="border-radius:2px;box-shadow:0 0 0 1px rgba(0,0,0,.15);vertical-align:middle;">
                            <span style="font-size:.75rem;vertical-align:middle;"> EN</span>
                        </a>
                    </li>

                    {% if app.user %}
                        <li class="nav-item">
                            <a href="{{ path('app_notifications') }}" class="nav-link em-notif-btn" title="Notifications">
                                <i class="bi bi-bell"></i>
                                <span class="em-notif-badge" id="notif-count" style="display:none"></span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_memorial_create') }}" class="btn em-btn-primary btn-sm">
                                <i class="bi bi-plus-circle"></i> {{ 'nav.create_memorial'|trans }}
                            </a>
                        </li>
                        <li class="nav-item dropdown em-user-menu">
                            <a class="nav-link dropdown-toggle em-user-toggle" href="#" data-bs-toggle="dropdown">
                                {% if app.user.avatarUrl %}
                                    <img src="{{ asset(app.user.avatarUrl) }}" alt="{{ app.user.fullName }}" class="em-avatar-sm">
                                {% else %}
                                    <span class="em-avatar-initials">{{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}</span>
                                {% endif %}
                                <span class="em-username d-none d-lg-inline">{{ app.user.firstName }}</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end em-user-dropdown">
                                <li class="dropdown-header">
                                    <strong>{{ app.user.fullName }}</strong>
                                    <small class="d-block text-muted">{{ app.user.email }}</small>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('app_dashboard') }}"><i class="bi bi-grid-1x2"></i> {{ 'nav.dashboard'|trans }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_profile') }}"><i class="bi bi-person-circle"></i> {{ 'nav.profile'|trans }}</a></li>
                                {% if is_granted('ROLE_MANAGER') %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('app_admin_dashboard') }}"><i class="bi bi-shield-lock"></i> {{ 'nav.admin'|trans }}</a></li>
                                {% endif %}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item em-logout" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right"></i> {{ 'nav.logout'|trans }}</a></li>
                            </ul>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a href="{{ path('app_login') }}" class="btn em-btn-outline btn-sm">
                                <i class="bi bi-person"></i> {{ 'nav.login'|trans }}
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_register') }}" class="btn em-btn-primary btn-sm">
                                {{ 'nav.register'|trans }}
                            </a>
                        </li>
                    {% endif %}
                </ul>

            </div>
        </div>
    </nav>
</header>

{% for type, messages in app.flashes %}
    {% for message in messages %}
    <div class="em-flash alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show"
         role="alert" style="margin:0;border-radius:0;">
        <div class="container-xl d-flex align-items-center gap-2">
            <i class="bi bi-{% if type == 'success' %}check-circle{% elseif type == 'error' or type == 'danger' %}exclamation-circle{% else %}info-circle{% endif %}"></i>
            {{ message }}
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    </div>
    {% endfor %}
{% endfor %}

<main class="em-main {% block main_class %}{% endblock %}" id="main-content">
    {% block body %}{% endblock %}
</main>

<footer class="em-footer">
    <div class="em-footer__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="currentColor"/>
        </svg>
    </div>
    <div class="em-footer__body">
        <div class="container-xl">
            <div class="row g-5">
                <div class="col-lg-4">
                    <a href="{{ path('app_home') }}" class="em-footer__logo">
                        <svg width="20" height="26" viewBox="0 0 26 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M13 2C13 2 4 9 4 18C4 23.523 8.477 28 14 28C19.523 28 24 23.523 24 18C24 12 18 8 17 4C17 4 16 10 12 12C12 12 14 7 13 2Z" fill="currentColor" opacity="0.85"/>
                        </svg>
                        <span>En<strong>Mémoire</strong>.com</span>
                    </a>
                    <p class="em-footer__tagline">{{ 'footer.tagline'|trans }}</p>
                    <div class="em-footer__social">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="WhatsApp"><i class="bi bi-whatsapp"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="em-footer__heading">{{ 'footer.platform'|trans }}</h6>
                    <ul class="em-footer__links">
                        <li><a href="{{ path('app_home') }}">{{ 'nav.home'|trans }}</a></li>
                        <li><a href="{{ path('app_memorial_search') }}">{{ 'nav.search'|trans }}</a></li>
                        <li><a href="{{ path('app_obituaries') }}">{{ 'nav.obituaries'|trans }}</a></li>
                        <li><a href="{{ path('app_gadget_shop') }}">{{ 'nav.shop'|trans }}</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="em-footer__heading">{{ 'footer.help'|trans }}</h6>
                    <ul class="em-footer__links">
                        <li><a href="{{ path('app_how_it_works') }}">{{ 'footer.how_it_works'|trans }}</a></li>
                        <li><a href="{{ path('app_pricing') }}">{{ 'footer.pricing'|trans }}</a></li>
                        <li><a href="{{ path('app_faq') }}">{{ 'footer.faq'|trans }}</a></li>
                        <li><a href="{{ path('app_contact') }}">{{ 'footer.contact'|trans }}</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="em-footer__heading">{{ 'footer.newsletter'|trans }}</h6>
                    <p class="em-footer__newsletter-text">{{ 'footer.newsletter_desc'|trans }}</p>
                    <form class="em-footer__newsletter-form" action="{{ path('app_newsletter_subscribe') }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('newsletter') }}">
                        <div class="input-group">
                            <input type="email" class="form-control" name="email"
                                   placeholder="{{ 'footer.newsletter_placeholder'|trans }}" required>
                            <button class="btn em-btn-primary" type="submit"><i class="bi bi-send"></i></button>
                        </div>
                    </form>
                    <div class="em-footer__badges">
                        <span class="em-badge-ssl"><i class="bi bi-shield-check"></i> SSL</span>
                        <span class="em-badge-rgpd"><i class="bi bi-lock"></i> RGPD</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="em-footer__bottom">
        <div class="container-xl">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="mb-0">&copy; {{ "now"|date("Y") }} EnMémoire.com — {{ 'footer.rights'|trans }}</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="{{ path('app_legal_terms') }}">{{ 'footer.terms'|trans }}</a>
                    <span class="mx-2">·</span>
                    <a href="{{ path('app_privacy') }}">{{ 'footer.privacy'|trans }}</a>
                    <span class="mx-2">·</span>
                    <a href="{{ path('app_cookies') }}">{{ 'footer.cookies'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('js/app.js') }}"></script>
{% block javascripts %}{% endblock %}
<script>
document.querySelectorAll('.em-flash').forEach(function(el){
    setTimeout(function(){ var a=bootstrap.Alert.getOrCreateInstance(el); if(a) a.close(); }, 6000);
});
</script>

<script>
(function() {
  var badge = document.getElementById('notif-count');
  if (!badge) return;

  function updateBadge(count) {
    if (count > 0) {
      badge.textContent = count > 99 ? '99+' : count;
      badge.style.display = 'flex';
    } else {
      badge.style.display = 'none';
    }
  }

  function fetchCount() {
    fetch('/notifications/count', {
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(data) { if (data) updateBadge(data.count); })
    .catch(function() {});
  }

  // Charger immédiatement puis toutes les 60 secondes
  fetchCount();
  setInterval(fetchCount, 60000);
})();
</script>

</body>
</html>
