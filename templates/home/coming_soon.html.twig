{% extends 'base.html.twig' %}
{% block title %}{{ feature }} — Bientôt disponible — EnMémoire.com{% endblock %}
{% block body %}
<div class="em-section text-center" style="min-height:60vh;display:flex;align-items:center;">
  <div class="container-xl">
    <div style="font-size:4rem;margin-bottom:1rem;">🚧</div>
    <h1 style="font-family:var(--font-display);">{{ feature }}</h1>
    <p class="text-muted">Cette fonctionnalité est en cours de développement et sera bientôt disponible.</p>
    <div class="d-flex gap-3 justify-content-center mt-4">
      <a href="{{ path('app_home') }}" class="em-btn em-btn--outline"><i class="bi bi-house"></i> Accueil</a>
      <a href="{{ path('app_dashboard') }}" class="em-btn em-btn--primary"><i class="bi bi-grid"></i> Dashboard</a>
    </div>
  </div>
</div>
{% endblock %}
