{% extends 'base.html.twig' %}
{% block title %}Mes gadgets MAKER — EnMémoire.com{% endblock %}

{% block stylesheets %}
<style>
.maker-index { max-width: 860px; margin: 2rem auto; padding: 0 1rem 4rem; }
.maker-index__header { text-align: center; margin-bottom: 2.5rem; }
.maker-index__header h1 { font-size: 1.6rem; margin: 0 0 .4rem; }
.maker-index__header p  { color: var(--em-muted); }

.event-card {
    background: var(--em-white); border-radius: 14px;
    box-shadow: 0 2px 10px rgba(0,0,0,.06);
    margin-bottom: 1.25rem; overflow: hidden;
    border: 2px solid transparent; transition: border-color .2s;
}
.event-card:hover { border-color: var(--em-gold); }
.event-card__header {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.1rem 1.25rem; cursor: pointer;
}
.event-card__cover {
    width: 56px; height: 56px; border-radius: 8px;
    object-fit: cover; background: var(--em-cream);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; flex-shrink: 0;
}
.event-card__info h3 { font-size: .95rem; margin: 0 0 .15rem; }
.event-card__info p  { font-size: .78rem; color: var(--em-muted); margin: 0; }
.event-card__body { padding: 0 1.25rem 1.25rem; border-top: 1px solid var(--em-border); }

.alloc-chip {
    display: inline-flex; align-items: center; gap: .35rem;
    background: var(--em-cream); border-radius: 20px;
    padding: .25rem .7rem; font-size: .78rem; font-weight: 600;
    color: var(--em-navy); margin: .25rem;
}
.alloc-chip.active   { background: rgba(34,197,94,.1);  color: #15803d; }
.alloc-chip.inactive { background: rgba(239,68,68,.08); color: #b91c1c; }

.wallet-bar {
    background: var(--em-cream); border-radius: 12px;
    padding: 1rem 1.25rem; margin-bottom: 2rem;
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    border: 1px solid var(--em-stone);
}
.wallet-chip {
    background: var(--em-white); border-radius: 20px;
    padding: .3rem .8rem; font-size: .82rem; font-weight: 600;
    border: 1.5px solid var(--em-border);
}

.empty-state { text-align: center; padding: 3rem; color: var(--em-muted); }
.empty-state .icon { font-size: 3rem; margin-bottom: .75rem; }
</style>
{% endblock %}

{% block body %}
<div class="maker-index">

    <div class="maker-index__header">
        <h1><i class="bi bi-magic me-2 text-gold"></i>Mes gadgets MAKER</h1>
        <p>Allouez des gadgets de votre portefeuille sur vos événements mémoriels.</p>
    </div>

    {# Portefeuille résumé #}
    <div class="wallet-bar">
        <i class="bi bi-wallet2" style="font-size:1.3rem;color:var(--em-gold);flex-shrink:0;"></i>
        <strong style="flex-shrink:0;">Mon portefeuille</strong>
        {% set hasWallet = false %}
        {% for gadget in gadgets %}
            {% if wallet[gadget.id] is defined and wallet[gadget.id] > 0 %}
                {% set hasWallet = true %}
                <span class="wallet-chip">
                    {% if gadget.type == 'flower' %}🌸
                    {% elseif gadget.type == 'candle' %}🕯️
                    {% elseif gadget.type == 'dove' %}🕊️
                    {% else %}✨{% endif %}
                    {{ gadget.name }} × {{ wallet[gadget.id] }}
                </span>
            {% endif %}
        {% endfor %}
        {% if not hasWallet %}
            <span style="color:var(--em-muted);font-size:.875rem;">Portefeuille vide.</span>
            <a href="{{ path('app_gadget_shop') }}" class="em-btn em-btn--primary ms-auto" style="padding:.4rem 1rem;font-size:.82rem;">
                <i class="bi bi-shop me-1"></i>Acheter des gadgets
            </a>
        {% else %}
            <a href="{{ path('app_gadget_wallet') }}" class="text-muted text-decoration-none ms-auto" style="font-size:.82rem;">
                Voir tout <i class="bi bi-arrow-right ms-1"></i>
            </a>
        {% endif %}
    </div>

    {# Liste des événements #}
    {% if events is empty %}
    <div class="empty-state">
        <div class="icon">📅</div>
        <p>Vous n'avez pas encore d'événements sur vos pages mémorielles.</p>
        <a href="{{ path('app_dashboard') }}" class="em-btn em-btn--outline mt-2">
            <i class="bi bi-house me-1"></i>Aller au dashboard
        </a>
    </div>

    {% else %}
    {% for item in events %}
    {% set event = item.event %}
    {% set page  = item.page %}
    {% set allocs = item.allocations %}
    {% set activeCount = allocs|filter(a => a.isActive)|length %}

    <div class="event-card">
        <div class="event-card__header">
            <div class="event-card__cover">
                {% if event.coverImageUrl %}
                    <img src="{{ event.coverImageUrl }}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" alt="">
                {% else %}
                    {% if event.type == 'funeral' %}⚰️
                    {% elseif event.type == 'memorial' %}🕯️
                    {% else %}📅{% endif %}
                {% endif %}
            </div>
            <div class="event-card__info" style="flex:1;">
                <h3>{{ event.title }}</h3>
                <p>
                    {{ page.deceasedFullName }} ·
                    {{ event.eventDate ? event.eventDate|date('d/m/Y') : '' }}
                    {% if event.locationName %} · {{ event.locationName }}{% endif %}
                </p>
            </div>
            <div style="flex-shrink:0;">
                {% if activeCount > 0 %}
                <span style="font-size:.78rem;background:rgba(34,197,94,.1);color:#15803d;padding:.2rem .6rem;border-radius:20px;font-weight:600;">
                    {{ activeCount }} allocation{{ activeCount > 1 ? 's' : '' }} active{{ activeCount > 1 ? 's' : '' }}
                </span>
                {% endif %}
            </div>
            <a href="{{ path('app_maker_event', {eventId: event.id}) }}"
               class="em-btn em-btn--primary" style="padding:.45rem 1rem;font-size:.82rem;flex-shrink:0;">
                <i class="bi bi-magic me-1"></i>Gérer
            </a>
        </div>

        {% if allocs is not empty %}
        <div class="event-card__body" style="padding-top:.75rem;">
            {% for alloc in allocs %}
            <span class="alloc-chip {{ alloc.isActive ? 'active' : 'inactive' }}">
                {% if alloc.gadget.type == 'flower' %}🌸
                {% elseif alloc.gadget.type == 'candle' %}🕯️
                {% elseif alloc.gadget.type == 'dove' %}🕊️
                {% else %}✨{% endif %}
                {{ alloc.gadget.name }}
                {% if alloc.totalQuantity is null %}∞
                {% else %}{{ alloc.remainingQuantity }}/{{ alloc.totalQuantity }}{% endif %}
                · {{ alloc.distributionMode == 'direct' ? 'Direct' : 'Exposé' }}
                {% if not alloc.isActive %} · Inactif{% endif %}
            </span>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endfor %}
    {% endif %}

</div>
{% endblock %}
