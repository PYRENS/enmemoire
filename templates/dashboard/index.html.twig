{% extends 'base.html.twig' %}
{# ============================================================ #}
{# DASHBOARD INDEX — Mes pages mémorielles                      #}
{# ============================================================ #}
{% block title %}Mon espace — EnMémoire.com{% endblock %}
{% block body_class %}dashboard-page{% endblock %}
{% block stylesheets %}<link rel="stylesheet" href="{{ asset('css/dashboard.css') }}">{% endblock %}
{% block body %}
<div class="dashboard-wrapper">
  {% include 'dashboard/partials/_sidebar.html.twig' %}
  <main class="dashboard-main">
    <div class="dashboard-main__header">
      <div>
        <h1 class="dashboard-main__title">Bonjour, {{ app.user.firstName }} 👋</h1>
        <p class="text-muted">Gérez vos pages mémorielles et vos notifications.</p>
      </div>
      <a href="{{ path('app_memorial_create') }}" class="em-btn em-btn--primary">
        <i class="bi bi-plus-circle"></i> Nouvelle page
      </a>
    </div>

    {% if myPages|length %}
    <div class="row g-4">
      {% for page in myPages %}
      <div class="col-md-6 col-xl-4">
        <div class="dashboard-card h-100">
          <div class="dashboard-card__body" style="padding:0;">
            <div style="height:100px;background:linear-gradient(135deg,var(--em-navy),var(--em-navy-light));border-radius:var(--em-radius-lg) var(--em-radius-lg) 0 0;position:relative;overflow:hidden;">
              {% if page.mainPhotoUrl %}
                <img src="{{ asset(page.mainPhotoUrl) }}" alt="" style="width:100%;height:100%;object-fit:cover;opacity:.4;">
              {% endif %}
              <div style="position:absolute;bottom:12px;left:12px;color:white;">
                <strong style="font-family:var(--font-display);font-size:1.1rem;">{{ page.deceasedFullName }}</strong>
                <small style="display:block;opacity:.7;">{{ page.deceasedBirthDate|date('Y') }} — {{ page.deceasedDeathDate|date('Y') }}</small>
              </div>
            </div>
            <div style="padding:1rem;">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="em-badge em-badge--{{ page.status == 'active' ? 'active' : 'pending' }}">
                  {{ page.status == 'active' ? 'Active' : page.status }}
                </span>
                <small class="text-muted">{{ page.formula.name }}</small>
              </div>
              <div class="d-flex gap-2 mt-3">
                <a href="{{ path('app_dashboard_memorial', {slug: page.slug}) }}" class="em-btn em-btn--primary em-btn--sm flex-fill">
                  <i class="bi bi-gear"></i> Gérer
                </a>
                <a href="{{ path('app_memorial_show', {slug: page.slug}) }}" class="em-btn em-btn--outline em-btn--sm" target="_blank">
                  <i class="bi bi-eye"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="dashboard-card">
      <div class="dashboard-empty" style="padding:3rem;">
        <i class="bi bi-flower1" style="font-size:3rem;color:var(--em-gold);opacity:.5;display:block;margin-bottom:1rem;"></i>
        <h3>Aucune page mémorielle</h3>
        <p>Créez votre première page mémorielle pour honorer la mémoire d'un proche.</p>
        <a href="{{ path('app_memorial_create') }}" class="em-btn em-btn--primary">
          <i class="bi bi-plus-circle"></i> Créer une page mémorielle
        </a>
      </div>
    </div>
    {% endif %}
  </main>
</div>
{% endblock %}
{% block javascripts %}<script src="{{ asset('js/dashboard.js') }}"></script>{% endblock %}
