{% extends 'base.html.twig' %}
{% block title %}Instructions de paiement — EnMémoire.com{% endblock %}

{% block body %}
<div class="container" style="max-width:600px;padding-top:2.5rem;padding-bottom:4rem;">

  <div class="dashboard-card">
    <div class="dashboard-card__header">
      <h3>📋 Instructions de paiement</h3>
    </div>
    <div class="dashboard-card__body">

      <div style="background:var(--em-cream);border-radius:var(--em-radius);padding:1rem;margin-bottom:1.5rem;">
        <p style="margin:0;font-size:.875rem;">
          <strong style="color:var(--em-navy);">{{ instructions.provider_label ?? payment.provider }}</strong>
          — Montant : <strong style="color:var(--em-gold);">{{ instructions.amount ?? payment.amount }} {{ instructions.currency ?? payment.currency }}</strong>
        </p>
        {% if instructions.reference is defined %}
        <p style="margin:.25rem 0 0;font-size:.8rem;color:var(--em-muted);">
          Référence : <strong>{{ instructions.reference }}</strong>
        </p>
        {% endif %}
      </div>

      {# Étapes #}
      <ol style="padding-left:1.25rem;margin-bottom:1.5rem;">
        {% for step in instructions.instructions ?? [] %}
        <li style="margin-bottom:.5rem;font-size:.9rem;color:var(--em-navy);line-height:1.5;">
          {{ step }}
        </li>
        {% endfor %}
      </ol>

      {# Coordonnées bancaires (virement) #}
      {% if instructions.bank_details is defined %}
      <div style="background:#F0FDF4;border:1px solid #BBF7D0;border-radius:var(--em-radius);padding:1rem;margin-bottom:1.5rem;">
        <h4 style="margin:0 0 .75rem;font-size:.9rem;color:#14532D;">🏦 Coordonnées bancaires</h4>
        {% for key, val in instructions.bank_details %}
        <div style="display:flex;justify-content:space-between;padding:.25rem 0;font-size:.85rem;border-bottom:1px solid #BBF7D0;">
          <span style="color:#16A34A;font-weight:600;">{{ key|capitalize }}</span>
          <span style="color:#14532D;">{{ val }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}

      {# Bouton confirmer #}
      {% if instructions.confirm_url is defined %}
      <div style="text-align:center;margin-top:1.5rem;">
        <a href="{{ instructions.confirm_url }}" class="em-btn em-btn--primary">
          <i class="bi bi-check-circle"></i> J'ai effectué le paiement
        </a>
      </div>
      {% endif %}

      <div style="margin-top:1rem;text-align:center;">
        <a href="{{ path('app_dashboard') }}" style="font-size:.825rem;color:var(--em-muted);">
          ← Retour au dashboard
        </a>
      </div>

    </div>
  </div>
</div>
{% endblock %}
