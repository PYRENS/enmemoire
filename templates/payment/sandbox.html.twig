{% extends 'base.html.twig' %}
{% block title %}Simulation de paiement — EnMémoire.com{% endblock %}
{% block body_class %}create-memorial-page{% endblock %}
{% block stylesheets %}<link rel="stylesheet" href="{{ asset('css/create.css') }}">{% endblock %}

{% block body %}
<div class="wizard-wrapper">
  <div class="container" style="max-width:520px;padding-top:4rem;padding-bottom:4rem;">
    <div class="wizard-card">

      {# En-tête sandbox #}
      <div class="sandbox-header">
        <div class="sandbox-badge">
          <i class="bi bi-bug"></i> Mode développement — Paiement simulé
        </div>
        <div class="sandbox-provider-icon sandbox-provider-icon--{{ provider }}">
          {% if provider == 'stripe' %}
            <svg viewBox="0 0 60 25" xmlns="http://www.w3.org/2000/svg" width="60" height="25">
              <path d="M59.64 14.28h-8.06c.19 1.93 1.63 2.48 3.45 2.48 1.64 0 2.96-.37 4.05-.95v3.32a12.08 12.08 0 0 1-4.56.92c-4.01 0-6.83-2.5-6.83-7.48 0-4.19 2.39-7.52 6.3-7.52 3.92 0 5.96 3.28 5.96 7.5 0 .4-.04 1.26-.31 1.73zm-5.69-5.43c-1.03 0-2.1.73-2.1 2.43h4.18c0-1.77-1.05-2.43-2.08-2.43zM35.3 5.84l-.14-.07a4.36 4.36 0 0 0-1.55-.3c-.98 0-1.5.56-1.5 1.32v.1h3.04v3.43H32.1v9.4H28.3v-9.4h-1.95V6.89h1.95V6.6c0-2.87 1.6-5.06 5.02-5.06 1.07 0 2.04.22 2.8.56l-.82 3.74zM23.41 5.25a2.26 2.26 0 1 1 0-4.51 2.26 2.26 0 0 1 0 4.51zm-1.9 1.64h3.8v12.83h-3.8V6.89zM14.48 10.1c0-1.1.9-1.54 2.04-1.54 1.47 0 3.19.45 4.52 1.26V6.18a12.31 12.31 0 0 0-4.52-.83c-3.72 0-6.2 1.94-6.2 5.17 0 5.06 6.96 4.25 6.96 6.44 0 1.3-1.13 1.71-2.35 1.71-2.04 0-4.16-.83-5.99-1.96v3.71a15.23 15.23 0 0 0 5.95 1.24c3.82 0 6.44-1.87 6.44-5.14 0-5.47-6.85-4.48-6.85-6.42zM0 7.25l3.83-.82.01 11.46H0z" fill="#6772E5"/>
            </svg>
          {% elseif provider == 'paypal' %}
            <span style="font-size:1.5rem;font-weight:800;color:#003087;">Pay<span style="color:#009cde;">Pal</span></span>
          {% else %}
            <i class="bi bi-phone" style="font-size:2rem;color:var(--em-gold);"></i>
          {% endif %}
        </div>
        <h1 class="sandbox-title">Paiement {{ label }}</h1>
        <p class="sandbox-subtitle">
          Ceci est une simulation. Aucun vrai paiement n'est effectué.
        </p>
      </div>

      {# Détails de la commande #}
      <div class="sandbox-order">
        <div class="sandbox-order__row">
          <span>Référence</span>
          <strong>EM-{{ '%06d'|format(payment.id) }}</strong>
        </div>
        <div class="sandbox-order__row">
          <span>Montant</span>
          <strong class="sandbox-amount">{{ payment.amount }} {{ payment.currency }}</strong>
        </div>
        <div class="sandbox-order__row">
          <span>Provider</span>
          <strong>{{ label }}</strong>
        </div>
        <div class="sandbox-order__row">
          <span>Statut</span>
          <span class="sandbox-status">En attente</span>
        </div>
      </div>

      {# Actions #}
      <form method="POST" class="sandbox-actions">
        <input type="hidden" name="_token" value="{{ csrf_token('sandbox_' ~ payment.id) }}">

        <button type="submit" name="action" value="success"
                class="em-btn em-btn--gold em-btn--lg w-100">
          <i class="bi bi-check-circle-fill"></i>
          ✅ Simuler un paiement réussi
        </button>

        <button type="submit" name="action" value="cancel"
                class="em-btn em-btn--ghost w-100 mt-2"
                style="color:var(--em-danger);">
          <i class="bi bi-x-circle"></i>
          ❌ Simuler un paiement échoué
        </button>
      </form>

      <div class="sandbox-note">
        <i class="bi bi-info-circle"></i>
        En production, cette page sera remplacée par la page de paiement réelle de <strong>{{ label }}</strong>.
        Configurez les clés API dans votre fichier <code>.env.local</code>.
      </div>

    </div>
  </div>
</div>
{% endblock %}
