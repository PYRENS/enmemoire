{% extends 'base.html.twig' %}
{% block title %}Demandes de connexion — {{ page.deceasedFullName }}{% endblock %}
{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/family.css') }}">
{% endblock %}

{% block body %}
<div class="container" style="max-width:800px;padding-top:2.5rem;padding-bottom:4rem;">

  <div class="family-header">
    <div style="display:flex;flex-direction:column;gap:.3rem;">
      <a href="{{ path('app_dashboard_memorial', {slug: page.slug}) }}" class="family-back">
        <i class="bi bi-speedometer2"></i> Dashboard
      </a>
      <a href="{{ path('app_family_tree', {slug: page.slug}) }}" class="family-back">
        <i class="bi bi-arrow-left"></i> Arbre familial
      </a>
    </div>
    <div>
      <h1>🔗 Demandes de connexion</h1>
      <p class="text-muted">Page de <strong>{{ page.deceasedFullName }}</strong></p>
    </div>
    <a href="{{ path('app_family_connect', {slug: page.slug}) }}" class="em-btn em-btn--primary">
      <i class="bi bi-person-plus"></i> Nouvelle demande
    </a>
  </div>

  {# Demandes REÇUES (à valider) #}
  <div class="family-requests-section">
    <h3 class="family-requests-title">
      <i class="bi bi-inbox"></i> Demandes reçues
      {% if received|length > 0 %}
        <span class="family-requests-badge">{{ received|length }}</span>
      {% endif %}
    </h3>

    {% if received is empty %}
    <div class="family-requests-empty">
      <i class="bi bi-inbox"></i>
      <p>Aucune demande en attente.</p>
    </div>
    {% else %}
    {% for conn in received %}
    <div class="family-request-card" id="req-{{ conn.id }}">
      <div class="family-request-card__person">
        <div class="family-list-avatar family-list-avatar--sm">
          {% if conn.memorialFrom.mainPhotoUrl %}
            <img src="{{ conn.memorialFrom.mainPhotoUrl starts with 'http' ? conn.memorialFrom.mainPhotoUrl : asset(conn.memorialFrom.mainPhotoUrl) }}" alt="">
          {% else %}
            {{ conn.memorialFrom.deceasedFirstName|first|upper }}
          {% endif %}
        </div>
        <div>
          <a href="{{ path('app_memorial_show', {slug: conn.memorialFrom.slug}) }}" target="_blank">
            <strong>{{ conn.memorialFrom.deceasedFullName }}</strong>
          </a>
          <small class="text-muted d-block">
            Demande le {{ conn.requestedAt|date('d/m/Y à H:i') }}
            {% if conn.requestedBy %}par {{ conn.requestedBy.fullName }}{% endif %}
          </small>
        </div>
      </div>

      <div class="family-request-card__relations">
        <span class="family-relation-badge">{{ conn.relationFrom }}</span>
        <i class="bi bi-arrow-left-right" style="color:var(--em-muted);font-size:.8rem;"></i>
        <span class="family-relation-badge">{{ conn.relationTo }}</span>
      </div>

      <div class="family-request-card__actions">
        <button onclick="acceptConnection({{ conn.id }})"
                class="em-btn em-btn--primary em-btn--sm" id="accept-{{ conn.id }}">
          <i class="bi bi-check-lg"></i> Accepter
        </button>
        <button onclick="rejectConnection({{ conn.id }})"
                class="em-btn em-btn--ghost em-btn--sm" style="color:var(--em-danger);"
                id="reject-{{ conn.id }}">
          <i class="bi bi-x-lg"></i> Refuser
        </button>
      </div>

      <span class="csrf-accept" data-id="{{ conn.id }}" style="display:none;">{{ csrf_token('family_accept_' ~ conn.id) }}</span>
      <span class="csrf-reject" data-id="{{ conn.id }}" style="display:none;">{{ csrf_token('family_reject_' ~ conn.id) }}</span>
    </div>
    {% endfor %}
    {% endif %}
  </div>

  {# Demandes ENVOYÉES #}
  <div class="family-requests-section">
    <h3 class="family-requests-title">
      <i class="bi bi-send"></i> Demandes envoyées
    </h3>

    {% if sent is empty %}
    <div class="family-requests-empty">
      <i class="bi bi-send"></i>
      <p>Aucune demande en attente d'envoi.</p>
    </div>
    {% else %}
    {% for conn in sent %}
    <div class="family-request-card family-request-card--sent" id="req-{{ conn.id }}">
      <div class="family-request-card__person">
        <div class="family-list-avatar family-list-avatar--sm">
          {% if conn.memorialTo.mainPhotoUrl %}
            <img src="{{ conn.memorialTo.mainPhotoUrl starts with 'http' ? conn.memorialTo.mainPhotoUrl : asset(conn.memorialTo.mainPhotoUrl) }}" alt="">
          {% else %}
            {{ conn.memorialTo.deceasedFirstName|first|upper }}
          {% endif %}
        </div>
        <div>
          <a href="{{ path('app_memorial_show', {slug: conn.memorialTo.slug}) }}" target="_blank">
            <strong>{{ conn.memorialTo.deceasedFullName }}</strong>
          </a>
          <small class="text-muted d-block">
            Envoyée le {{ conn.requestedAt|date('d/m/Y à H:i') }}
          </small>
        </div>
      </div>

      <div class="family-request-card__relations">
        <span class="family-relation-badge">{{ conn.relationFrom }}</span>
        <i class="bi bi-arrow-left-right" style="color:var(--em-muted);font-size:.8rem;"></i>
        <span class="family-relation-badge">{{ conn.relationTo }}</span>
      </div>

      <span class="family-status-badge family-status-badge--pending">
        <i class="bi bi-clock"></i> En attente
      </span>
    </div>
    {% endfor %}
    {% endif %}
  </div>

  {# Connexions ACCEPTÉES #}
  {% if accepted is not empty %}
  <div class="family-requests-section">
    <h3 class="family-requests-title">
      <i class="bi bi-check-circle"></i> Connexions actives ({{ accepted|length }})
    </h3>
    {% for conn in accepted %}
      {% set other = conn.memorialFrom.id == page.id ? conn.memorialTo : conn.memorialFrom %}
      {% set relation = conn.memorialFrom.id == page.id ? conn.relationFrom : conn.relationTo %}
    <div class="family-request-card family-request-card--accepted" id="req-{{ conn.id }}">
      <div class="family-request-card__person">
        <div class="family-list-avatar family-list-avatar--sm">
          {% if other.mainPhotoUrl %}
            <img src="{{ other.mainPhotoUrl starts with 'http' ? other.mainPhotoUrl : asset(other.mainPhotoUrl) }}" alt="">
          {% else %}{{ other.deceasedFirstName|first|upper }}{% endif %}
        </div>
        <div>
          <a href="{{ path('app_memorial_show', {slug: other.slug}) }}" target="_blank">
            <strong>{{ other.deceasedFullName }}</strong>
          </a>
          <small class="text-muted d-block">Relation : {{ relation }}</small>
        </div>
      </div>
      <span class="family-status-badge family-status-badge--accepted">
        <i class="bi bi-check-circle"></i> Acceptée
      </span>
      <button onclick="deleteConn({{ conn.id }})" class="family-list-item__delete" title="Supprimer">
        <i class="bi bi-x-lg"></i>
      </button>
      <span class="csrf-delete" data-id="{{ conn.id }}" style="display:none;">{{ csrf_token('family_delete_' ~ conn.id) }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}

</div>
{% endblock %}

{% block javascripts %}
<script>
var PAGE_SLUG = '{{ page.slug }}';

async function acceptConnection(id) {
  var csrf = document.querySelector('.csrf-accept[data-id="'+id+'"]')?.textContent?.trim();
  var form = new FormData(); form.append('_token', csrf);
  var resp = await fetch('/memorial/'+PAGE_SLUG+'/famille/accepter/'+id, {method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}});
  var data = await resp.json();
  if (data.success) {
    var card = document.getElementById('req-'+id);
    card.querySelector('.family-request-card__actions').innerHTML =
      '<span class="family-status-badge family-status-badge--accepted"><i class="bi bi-check-circle"></i> Acceptée</span>';
    card.classList.add('family-request-card--accepted');
  } else alert(data.error || 'Erreur');
}

async function rejectConnection(id) {
  if (!confirm('Refuser cette demande de connexion ?')) return;
  var csrf = document.querySelector('.csrf-reject[data-id="'+id+'"]')?.textContent?.trim();
  var form = new FormData(); form.append('_token', csrf);
  var resp = await fetch('/memorial/'+PAGE_SLUG+'/famille/refuser/'+id, {method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}});
  var data = await resp.json();
  if (data.success) document.getElementById('req-'+id)?.remove();
  else alert(data.error || 'Erreur');
}

async function deleteConn(id) {
  if (!confirm('Supprimer cette connexion familiale ?')) return;
  var csrf = document.querySelector('.csrf-delete[data-id="'+id+'"]')?.textContent?.trim();
  var form = new FormData(); form.append('_token', csrf);
  var resp = await fetch('/memorial/'+PAGE_SLUG+'/famille/supprimer/'+id, {method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}});
  var data = await resp.json();
  if (data.success) document.getElementById('req-'+id)?.remove();
  else alert(data.error || 'Erreur');
}
</script>
{% endblock %}
