{% extends 'base.html.twig' %}
{% block title %}Arbre familial — {{ page.deceasedFullName }}{% endblock %}
{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/family.css') }}">
{% endblock %}

{% block body %}
<div class="container-xl" style="padding-top:2rem;padding-bottom:4rem;">

  {# En-tête #}
  <div class="family-header">
    <a href="{{ path('app_memorial_show', {slug: page.slug}) }}" class="family-back">
      <i class="bi bi-arrow-left"></i> Page mémorielle
    </a>
    <div>
      <h1>🌳 Arbre familial</h1>
      <p class="text-muted">{{ page.deceasedFullName }}</p>
    </div>
    {% if isModerator %}
    <a href="{{ path('app_family_requests', {slug: page.slug}) }}" class="em-btn em-btn--ghost" style="margin-right:.5rem;"><i class="bi bi-clock-history"></i> Demandes</a><a href="{{ path('app_family_connect', {slug: page.slug}) }}" class="em-btn em-btn--primary">
      <i class="bi bi-person-plus"></i> Ajouter un membre
    </a>
    {% endif %}
  </div>

  {% if connections is empty %}
  {# État vide #}
  <div class="family-empty">
    <div class="family-empty__icon">🌱</div>
    <h3>L'arbre familial est vide</h3>
    <p>Connectez d'autres pages mémorielles pour construire l'arbre familial de {{ page.deceasedFirstName }}.</p>
    {% if isModerator %}
    <a href="{{ path('app_family_requests', {slug: page.slug}) }}" class="em-btn em-btn--ghost" style="margin-right:.5rem;"><i class="bi bi-clock-history"></i> Demandes</a><a href="{{ path('app_family_connect', {slug: page.slug}) }}" class="em-btn em-btn--primary">
      <i class="bi bi-person-plus"></i> Ajouter le premier membre
    </a>
    {% endif %}
  </div>

  {% else %}

  {# Switcher vue #}
  <div class="family-view-switch">
    <button class="family-view-btn" onclick="switchView('list')" id="btn-list">
      <i class="bi bi-list-ul"></i> Liste
    </button>
    <button class="family-view-btn active" onclick="switchView('graph')" id="btn-graph">
      <i class="bi bi-diagram-3"></i> Graphique
    </button>
  </div>

  {# VUE GRAPHIQUE (desktop) #}
  <div id="view-graph" class="family-graph-wrap">
    <div class="family-graph-controls">
      <button onclick="zoomIn()" class="family-ctrl-btn" title="Zoom +"><i class="bi bi-plus-lg"></i></button>
      <button onclick="zoomOut()" class="family-ctrl-btn" title="Zoom -"><i class="bi bi-dash-lg"></i></button>
      <button onclick="resetZoom()" class="family-ctrl-btn" title="Réinitialiser"><i class="bi bi-arrows-fullscreen"></i></button>
    </div>
    <svg id="family-svg" width="100%" height="600"></svg>
  </div>

  {# VUE LISTE (mobile + toggle) #}
  <div id="view-list" class="family-list-wrap" style="display:none;">
    {# Nœud central #}
    <div class="family-list-central">
      <div class="family-list-avatar family-list-avatar--central">
        {% if page.mainPhotoUrl %}
          <img src="{{ page.mainPhotoUrl starts with 'http' ? page.mainPhotoUrl : asset(page.mainPhotoUrl) }}"
               alt="{{ page.deceasedFullName }}">
        {% else %}
          {{ page.deceasedFirstName|first|upper }}
        {% endif %}
      </div>
      <div>
        <strong>{{ page.deceasedFullName }}</strong>
        <small class="text-muted d-block">
          {{ page.deceasedBirthDate|date('Y') }} – {{ page.deceasedDeathDate|date('Y') }}
        </small>
      </div>
    </div>

    {# Relations #}
    {% for connection in connections %}
      {% set isCentral = connection.memorialFrom.id == page.id %}
      {% set relative  = isCentral ? connection.memorialTo : connection.memorialFrom %}
      {% set relation  = isCentral ? connection.relationFrom : connection.relationTo %}

      <div class="family-list-item" id="conn-{{ connection.id }}">
        <div class="family-list-item__relation">{{ relation }}</div>
        <a href="{{ path('app_memorial_show', {slug: relative.slug}) }}" class="family-list-item__person">
          <div class="family-list-avatar">
            {% if relative.mainPhotoUrl %}
              <img src="{{ relative.mainPhotoUrl starts with 'http' ? relative.mainPhotoUrl : asset(relative.mainPhotoUrl) }}"
                   alt="{{ relative.deceasedFullName }}">
            {% else %}
              {{ relative.deceasedFirstName|first|upper }}
            {% endif %}
          </div>
          <div>
            <strong>{{ relative.deceasedFullName }}</strong>
            <small class="text-muted d-block">
              {{ relative.deceasedBirthDate|date('Y') }} – {{ relative.deceasedDeathDate|date('Y') }}
            </small>
          </div>
        </a>
        {% if isModerator %}
        <button onclick="deleteConnection({{ connection.id }})"
                class="family-list-item__delete" title="Supprimer">
          <i class="bi bi-x-lg"></i>
        </button>
        <span class="csrf-family-delete" data-id="{{ connection.id }}" style="display:none;">
          {{ csrf_token('family_delete_' ~ connection.id) }}
        </span>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {% endif %}

</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<script>
var TREE_DATA = {{ treeData|json_encode|raw }};
var PAGE_SLUG = '{{ page.slug }}';
var IS_MOBILE = window.innerWidth < 768;
var _svg=null,_zoom=null,_sim=null,_graphInit=false;

function switchView(view) {
  document.getElementById('view-graph').style.display = view==='graph' ? 'block' : 'none';
  document.getElementById('view-list').style.display  = view==='list'  ? 'block' : 'none';
  document.getElementById('btn-graph').classList.toggle('active', view==='graph');
  document.getElementById('btn-list').classList.toggle('active', view==='list');
  if (view==='graph' && !_graphInit) { _graphInit=true; setTimeout(initGraph, 100); }
}

document.addEventListener('DOMContentLoaded', function(){ switchView('list'); });

function initGraph() {
  if (!TREE_DATA.nodes.length) return;
  var svgEl = document.getElementById('family-svg');
  if (!svgEl) return;
  var W = svgEl.parentElement.clientWidth || 800;
  var H = 580;
  svgEl.setAttribute('width', W);
  svgEl.setAttribute('height', H);
  d3.select('#family-svg').selectAll('*').remove();
  _svg = d3.select('#family-svg');
  _zoom = d3.zoom().scaleExtent([0.2,4]).on('zoom',function(e){ gMain.attr('transform',e.transform); });
  _svg.call(_zoom);
  var gMain = _svg.append('g');
  var nodes = TREE_DATA.nodes.map(function(d){ return Object.assign({},d); });
  var edges = TREE_DATA.edges.map(function(d){
    var e = {};
    e.source = String(d.from);
    e.target = String(d.to);
    e.relFrom = d.relationFrom;
    e.relTo = d.relationTo;
    e.id = d.id;
    return e;
  });
  var cx=W/2, cy=H/2;
  nodes.forEach(function(n,i){
    n.x = n.isCentral ? cx : cx+220*Math.cos(2*Math.PI*i/Math.max(nodes.length,1));
    n.y = n.isCentral ? cy : cy+160*Math.sin(2*Math.PI*i/Math.max(nodes.length,1));
  });
  var defs=_svg.append('defs');
  nodes.forEach(function(n){
    if(n.photo){
      defs.append('clipPath').attr('id','clip-'+n.id)
        .append('circle')
          .attr('cx', 0)
          .attr('cy', 0)
          .attr('r', n.isCentral ? 38 : 28);
    }
  });
  var linkSel = gMain.append('g').selectAll('line').data(edges).enter().append('line')
    .attr('stroke','#C9A84C').attr('stroke-width',2).attr('opacity',0.8);
  var labelSel = gMain.append('g').selectAll('text').data(edges).enter().append('text')
    .attr('text-anchor','middle').attr('font-size','10px').attr('fill','#9CA3AF')
    .text(function(d){ return d.relFrom+' / '+d.relTo; });
  var nodeSel = gMain.append('g').selectAll('g').data(nodes).enter().append('g')
    .style('cursor','pointer')
    .on('click',function(e,d){ if(!e.defaultPrevented) window.location.href='/memorial/'+d.slug; })
    .call(d3.drag()
      .on('start',function(e,d){ if(!e.active)_sim.alphaTarget(0.3).restart(); d.fx=d.x;d.fy=d.y; })
      .on('drag', function(e,d){ d.fx=e.x;d.fy=e.y; })
      .on('end',  function(e,d){ if(!e.active)_sim.alphaTarget(0); d.fx=d.x;d.fy=d.y; })
    );
  nodeSel.append('circle')
    .attr('r',function(d){ return d.isCentral?40:30; })
    .attr('fill',function(d){ return d.isCentral?'#F8F4EE':'white'; })
    .attr('stroke',function(d){ return d.isCentral?'#C9A84C':'#1B2B4B'; })
    .attr('stroke-width',function(d){ return d.isCentral?3:2; });
  nodeSel.each(function(d){
    var n=d3.select(this),r=d.isCentral?38:28;
    if(d.photo){
      var url=d.photo.startsWith('http')?d.photo:'/'+d.photo.replace(/^\//,'');
      n.append('image')
        .attr('href', url)
        .attr('x', -r)
        .attr('y', -r)
        .attr('width', r*2)
        .attr('height', r*2)
        .attr('preserveAspectRatio', 'xMidYMid slice')
        .attr('clip-path', 'url(#clip-'+d.id+')');
    } else {
      n.append('text').attr('text-anchor','middle').attr('dy','0.35em')
        .attr('font-size',d.isCentral?'1.2rem':'1rem').attr('fill','#1B2B4B')
        .text(d.label.split(' ').slice(0,2).map(function(w){ return w[0]; }).join('').toUpperCase());
    }
  });
  nodeSel.append('text').attr('text-anchor','middle')
    .attr('y',function(d){ return d.isCentral?56:44; })
    .attr('font-size','12px').attr('font-weight','600').attr('fill','#1B2B4B')
    .text(function(d){ return d.label.split(' ')[0]; });
  nodeSel.append('text').attr('text-anchor','middle')
    .attr('y',function(d){ return d.isCentral?70:58; })
    .attr('font-size','10px').attr('fill','#9CA3AF')
    .text(function(d){ return d.dates||''; });
  _sim = d3.forceSimulation(nodes)
    .force('link',d3.forceLink(edges).id(function(d){ return String(d.id); }).distance(200).strength(0.8))
    .force('charge',d3.forceManyBody().strength(-500))
    .force('center',d3.forceCenter(cx,cy))
    .force('collision',d3.forceCollide(70))
    .on('tick',function(){
      linkSel
        .attr('x1',function(d){ return d.source?d.source.x:cx; })
        .attr('y1',function(d){ return d.source?d.source.y:cy; })
        .attr('x2',function(d){ return d.target?d.target.x:cx; })
        .attr('y2',function(d){ return d.target?d.target.y:cy; });
      labelSel
        .attr('x',function(d){ return d.source&&d.target?(d.source.x+d.target.x)/2:cx; })
        .attr('y',function(d){ return d.source&&d.target?(d.source.y+d.target.y)/2-6:cy; });
      nodeSel.attr('transform',function(d){
        return 'translate('+(isNaN(d.x)?cx:d.x)+','+(isNaN(d.y)?cy:d.y)+')';
      });
    });
}

function zoomIn()    { if(_svg&&_zoom) _svg.transition().duration(300).call(_zoom.scaleBy,1.5); }
function zoomOut()   { if(_svg&&_zoom) _svg.transition().duration(300).call(_zoom.scaleBy,0.67); }
function resetZoom() { if(_svg&&_zoom) _svg.transition().duration(300).call(_zoom.transform,d3.zoomIdentity); }

async function deleteConnection(id) {
  if(!confirm('Supprimer cette connexion familiale ?')) return;
  var csrf=document.querySelector('.csrf-family-delete[data-id="'+id+'"]')?.textContent?.trim();
  var form=new FormData(); form.append('_token',csrf);
  var resp=await fetch('/memorial/'+PAGE_SLUG+'/famille/supprimer/'+id,{
    method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}
  });
  var data=await resp.json();
  if(data.success){ document.getElementById('conn-'+id)?.remove(); }
  else alert(data.error||'Erreur');
}
</script>
{% endblock %}
