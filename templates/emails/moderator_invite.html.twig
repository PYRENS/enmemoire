<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"><title>Invitation — EnMémoire.com</title></head>
<body style="margin:0;padding:0;background:#F4F6F9;font-family:'Segoe UI',Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="padding:32px 16px;">
<tr><td align="center">
<table width="560" cellpadding="0" cellspacing="0"
       style="background:white;border-radius:16px;box-shadow:0 4px 24px rgba(27,43,75,.1);overflow:hidden;max-width:560px;width:100%;">

  <tr><td style="background:linear-gradient(135deg,#1B2B4B,#2C4270);padding:28px 32px;text-align:center;">
    <h1 style="color:white;font-weight:300;font-size:22px;margin:0;">
      🕯️ <span style="color:#C9A84C;">En</span>Mémoire<span style="color:#C9A84C;">.com</span>
    </h1>
  </td></tr>

  <tr><td style="padding:32px;">
    <h2 style="color:#1B2B4B;font-size:20px;font-weight:400;margin:0 0 12px;">
      Invitation à co-gérer une page mémorielle
    </h2>

    <p style="color:#6B7280;font-size:15px;line-height:1.6;margin:0 0 20px;">
      {% if invitedBy %}
        <strong style="color:#1B2B4B;">{{ invitedBy.fullName }}</strong> vous invite à co-gérer
        la page mémorielle de <strong style="color:#1B2B4B;">{{ page.deceasedFullName }}</strong>.
      {% else %}
        Vous avez été invité à co-gérer la page mémorielle de
        <strong style="color:#1B2B4B;">{{ page.deceasedFullName }}</strong>.
      {% endif %}
    </p>

    {% if note %}
    <div style="background:#F8F4EE;border-radius:10px;padding:14px 16px;margin-bottom:20px;
                border-left:3px solid #C9A84C;font-size:.9rem;color:#2D2D2D;font-style:italic;">
      « {{ note }} »
    </div>
    {% endif %}

    <div style="background:#F4F6F9;border-radius:10px;padding:14px 16px;margin-bottom:24px;
                display:flex;align-items:center;gap:12px;">
      <div>
        <strong style="color:#1B2B4B;display:block;">{{ page.deceasedFullName }}</strong>
        <span style="font-size:.8rem;color:#6B7280;">
          {{ page.deceasedBirthDate|date('Y') }} — {{ page.deceasedDeathDate|date('Y') }}
        </span>
      </div>
    </div>

    <div style="text-align:center;margin:0 0 24px;">
      <a href="{{ accept_url }}"
         style="display:inline-block;background:#1B2B4B;color:white;text-decoration:none;
                padding:14px 32px;border-radius:8px;font-size:15px;font-weight:600;">
        ✅ Accepter l'invitation
      </a>
    </div>

    <div style="background:#F8F4EE;border-radius:8px;padding:12px 16px;font-size:.8rem;color:#6B7280;">
      <strong>Code d'invitation :</strong> <code style="color:#1B2B4B;">{{ code }}</code><br>
      Ou collez ce lien dans votre navigateur :<br>
      <a href="{{ accept_url }}" style="color:#C9A84C;word-break:break-all;">{{ accept_url }}</a>
    </div>

    <p style="font-size:.78rem;color:#9CA3AF;text-align:center;margin:20px 0 0;">
      Si vous n'attendiez pas cette invitation, ignorez cet email.
    </p>
  </td></tr>

  <tr><td style="background:#F8F4EE;border-top:1px solid #E8E0D4;padding:14px 32px;text-align:center;">
    <p style="color:#9CA3AF;font-size:12px;margin:0;">
      © {{ "now"|date("Y") }} EnMémoire.com
    </p>
  </td></tr>

</table>
</td></tr>
</table>
</body>
</html>
