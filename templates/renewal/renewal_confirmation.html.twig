<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"><title>Renouvellement confirmé — EnMémoire.com</title></head>
<body style="margin:0;padding:0;background:#F4F6F9;font-family:'Segoe UI',Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="padding:32px 16px;">
<tr><td align="center">
<table width="580" cellpadding="0" cellspacing="0"
       style="background:white;border-radius:16px;box-shadow:0 4px 24px rgba(27,43,75,.1);overflow:hidden;max-width:580px;width:100%;">

  {# Header #}
  <tr><td style="background:linear-gradient(135deg,#1B2B4B,#2C4270);padding:28px 32px;text-align:center;">
    <h1 style="color:white;font-weight:300;font-size:22px;margin:0 0 4px;">
      ✅ <span style="color:#C9A84C;">En</span>Mémoire<span style="color:#C9A84C;">.com</span>
    </h1>
    <p style="color:rgba(255,255,255,.7);margin:0;font-size:13px;">Renouvellement confirmé</p>
  </td></tr>

  {# Corps #}
  <tr><td style="padding:32px;">

    <p style="color:#6B7280;font-size:15px;line-height:1.6;margin:0 0 20px;">
      Bonjour <strong style="color:#1B2B4B;">{{ owner.firstName }}</strong>,
      votre renouvellement a été traité avec succès.
      La page mémorielle de <strong style="color:#1B2B4B;">{{ page.deceasedFullName }}</strong>
      est maintenant active jusqu'au
      <strong style="color:#C9A84C;">{{ page.expiresAt|date('d/m/Y') }}</strong>.
    </p>

    {# Récap #}
    <div style="background:#F8F4EE;border-radius:12px;padding:16px;margin-bottom:24px;">
      <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #E8E0D4;font-size:14px;">
        <span style="color:#6B7280;">Page mémorielle</span>
        <strong style="color:#1B2B4B;">{{ page.deceasedFullName }}</strong>
      </div>
      <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #E8E0D4;font-size:14px;">
        <span style="color:#6B7280;">Formule</span>
        <strong style="color:#1B2B4B;">{{ page.formula ? page.formula.name : '—' }}</strong>
      </div>
      <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #E8E0D4;font-size:14px;">
        <span style="color:#6B7280;">Valide jusqu'au</span>
        <strong style="color:#C9A84C;">{{ page.expiresAt|date('d/m/Y') }}</strong>
      </div>
      <div style="display:flex;justify-content:space-between;padding:6px 0;font-size:14px;">
        <span style="color:#6B7280;">Montant payé</span>
        <strong style="color:#1B2B4B;">{{ payment.amount }} {{ payment.currency }}</strong>
      </div>
    </div>

    {# Bouton #}
    <div style="text-align:center;margin-bottom:24px;">
      <a href="{{ dashboard_url }}"
         style="display:inline-block;background:#1B2B4B;color:white;text-decoration:none;
                padding:14px 32px;border-radius:8px;font-size:15px;font-weight:600;">
        🏠 Accéder au dashboard
      </a>
    </div>

    {# Séparateur facture #}
    <div style="border-top:2px dashed #E8E0D4;margin:24px 0;"></div>
    <h3 style="color:#1B2B4B;font-size:16px;font-weight:600;margin:0 0 16px;">
      🧾 Reçu de paiement
    </h3>

    {# Facture #}
    <table width="100%" cellpadding="0" cellspacing="0"
           style="border:1px solid #E8E0D4;border-radius:8px;overflow:hidden;font-size:13px;">
      <tr style="background:#F8F4EE;">
        <td style="padding:10px 16px;font-weight:600;color:#1B2B4B;">EnMémoire.com</td>
        <td style="padding:10px 16px;text-align:right;color:#6B7280;">
          Reçu N° {{ payment.uuid|slice(0,8)|upper }}
        </td>
      </tr>
      <tr>
        <td colspan="2" style="padding:12px 16px;border-top:1px solid #E8E0D4;">
          <table width="100%" cellpadding="0" cellspacing="0">
            <tr>
              <td style="color:#6B7280;padding:3px 0;">Date</td>
              <td style="text-align:right;color:#1B2B4B;">{{ payment.createdAt|date('d/m/Y H:i') }}</td>
            </tr>
            <tr>
              <td style="color:#6B7280;padding:3px 0;">Référence</td>
              <td style="text-align:right;color:#1B2B4B;font-family:monospace;">EM-{{ '%06d'|format(payment.id) }}</td>
            </tr>
            <tr>
              <td style="color:#6B7280;padding:3px 0;">Provider</td>
              <td style="text-align:right;color:#1B2B4B;">{{ payment.provider|replace({'_': ' '})|title }}</td>
            </tr>
            {% if payment.providerTxId %}
            <tr>
              <td style="color:#6B7280;padding:3px 0;">Transaction ID</td>
              <td style="text-align:right;color:#1B2B4B;font-size:11px;font-family:monospace;">{{ payment.providerTxId }}</td>
            </tr>
            {% endif %}
          </table>
        </td>
      </tr>
      <tr style="background:#F8F4EE;border-top:1px solid #E8E0D4;">
        <td style="padding:10px 16px;font-weight:700;color:#1B2B4B;">Total</td>
        <td style="padding:10px 16px;text-align:right;font-weight:700;font-size:16px;color:#C9A84C;">
          {{ payment.amount }} {{ payment.currency }}
        </td>
      </tr>
    </table>

    <p style="font-size:.75rem;color:#9CA3AF;text-align:center;margin:16px 0 0;">
      Conservez cet email comme preuve de paiement.
    </p>

  </td></tr>

  {# Footer #}
  <tr><td style="background:#F8F4EE;border-top:1px solid #E8E0D4;padding:14px 32px;text-align:center;">
    <p style="color:#9CA3AF;font-size:12px;margin:0;">
      © {{ "now"|date("Y") }} EnMémoire.com · <a href="{{ page_url }}" style="color:#C9A84C;">Voir la page</a>
    </p>
  </td></tr>

</table>
</td></tr>
</table>
</body>
</html>
