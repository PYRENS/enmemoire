{# templates/profile/password.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Changer mon mot de passe — EnMémoire.com{% endblock %}
{% block stylesheets %}<link rel="stylesheet" href="{{ asset('css/profile.css') }}">{% endblock %}
{% block body %}
<div class="profile-layout container-xl">
  {% include 'profile/_sidebar.html.twig' with {active: 'password'} %}
  <main class="profile-main">
    <div class="profile-section">
      <div class="profile-section__header"><h3>Changer mon mot de passe</h3></div>

      {% if error %}<div class="profile-alert profile-alert--error"><i class="bi bi-exclamation-circle"></i> {{ error }}</div>{% endif %}

      <form method="POST" action="{{ path('app_profile_password') }}" class="profile-form">
        <input type="hidden" name="_token" value="{{ csrf_token('profile_password') }}">

        <div class="profile-form-group">
          <label>Mot de passe actuel *</label>
          <div class="profile-input-wrap">
            <input type="password" name="current_password" class="profile-input" required autocomplete="current-password">
            <button type="button" class="profile-toggle-pw"><i class="bi bi-eye"></i></button>
          </div>
        </div>

        <div class="profile-form-group">
          <label>Nouveau mot de passe * <small>(8 caractères min.)</small></label>
          <div class="profile-input-wrap">
            <input type="password" name="new_password" id="new-pw" class="profile-input"
                   required minlength="8" autocomplete="new-password">
            <button type="button" class="profile-toggle-pw"><i class="bi bi-eye"></i></button>
          </div>
          <div class="profile-pw-strength"><div class="profile-pw-bar" id="pw-bar"></div></div>
        </div>

        <div class="profile-form-group">
          <label>Confirmer le nouveau mot de passe *</label>
          <div class="profile-input-wrap">
            <input type="password" name="confirm_password" id="confirm-pw" class="profile-input"
                   required autocomplete="new-password">
          </div>
          <div id="pw-match" style="font-size:.8rem;margin-top:4px;min-height:18px;"></div>
        </div>

        <div class="profile-form-actions">
          <a href="{{ path('app_profile') }}" class="em-btn em-btn--ghost">Annuler</a>
          <button type="submit" class="em-btn em-btn--primary">
            <i class="bi bi-shield-check"></i> Changer le mot de passe
          </button>
        </div>
      </form>
    </div>
  </main>
</div>
{% endblock %}
{% block javascripts %}
<script>
// Force mdp
document.getElementById('new-pw')?.addEventListener('input', function() {
  const v = this.value;
  let score = [v.length>=8, /[A-Z]/.test(v), /[0-9]/.test(v), /[^A-Za-z0-9]/.test(v)].filter(Boolean).length;
  const bar = document.getElementById('pw-bar');
  bar.style.width = (score/4*100)+'%';
  bar.style.background = ['#EF4444','#F97316','#EAB308','#22C55E'][score-1]||'#EF4444';
});
// Confirmation
document.getElementById('confirm-pw')?.addEventListener('input', function() {
  const msg = document.getElementById('pw-match');
  const match = this.value === document.getElementById('new-pw').value;
  msg.textContent = this.value ? (match ? '✓ Mots de passe identiques' : '✗ Mots de passe différents') : '';
  msg.style.color = match ? '#22C55E' : '#EF4444';
});
// Toggle visibilité
document.querySelectorAll('.profile-toggle-pw').forEach(btn => {
  btn.addEventListener('click', () => {
    const input = btn.previousElementSibling;
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.querySelector('i').className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
  });
});
</script>
{% endblock %}
