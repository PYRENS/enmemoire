function editGalleryCaption(id,current){var caption=prompt('Légende :',current);if(caption===null)return;var csrf=document.querySelector('.mgal-csrf-caption[data-id="'+id+'"]')?.textContent?.trim();var form=new FormData();form.append('_token',csrf);form.append('caption',caption);fetch('/memorial/'+PAGE_SLUG+'/media/galerie/'+id+'/caption',{method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}}).then(r=>r.json()).then(data=>{if(data.success){var cap=document.querySelector('#gallery-item-'+id+' .memorial-gallery__caption');if(caption){if(cap)cap.textContent=caption;else{var c=document.createElement('div');c.className='memorial-gallery__caption';c.textContent=caption;document.querySelector('#gallery-item-'+id+' a')?.appendChild(c);}}else if(cap)cap.remove();}});}

function switchGalleryTab(tab, btn) {
  // Masquer toutes les sections
  document.querySelectorAll('.gallery-section').forEach(function(s){ s.style.display='none'; });
  // Désactiver tous les tabs
  document.querySelectorAll('.gallery-tab').forEach(function(b){ b.classList.remove('active'); });
