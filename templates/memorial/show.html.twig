{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/memorial.js') }}"></script>
<script>
const MEMORIAL_SLUG = '{{ page.slug }}';

// Onglets
function openTab(name) {
  document.querySelectorAll('.memorial-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.memorial-tab').forEach(t => t.classList.remove('active'));
  const panel = document.getElementById('panel-' + name);
  const tab   = document.getElementById('tab-' + name);
  if (panel) panel.classList.add('active');
  if (tab)   tab.classList.add('active');
  document.getElementById('memorial-tabs').scrollIntoView({behavior: 'smooth', block: 'nearest'});
}

// Copier le lien
function copyPageLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    const btn = document.getElementById('copy-page-btn');
    btn.innerHTML = '<i class="bi bi-check-lg"></i> Copié !';
    setTimeout(() => { btn.innerHTML = '<i class="bi bi-link-45deg"></i> Copier le lien'; }, 2000);
  });
}

// Formulaire condoléance
document.getElementById('condolence-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn  = document.getElementById('condolence-submit');
  btn.disabled = true;
  btn.innerHTML = '<i class="bi bi-hourglass"></i> Envoi…';

  const resp = await fetch(`/memorial/${MEMORIAL_SLUG}/condolence`, {
    method: 'POST',
    body:   new FormData(this),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });
  const data = await resp.json();

  if (data.error) {
    alert(data.error);
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-send"></i> Publier';
    return;
  }

  if (data.html) {
    document.getElementById('condolences-list').insertAdjacentHTML('afterbegin', data.html);
  }

  this.reset();
  btn.innerHTML = '<i class="bi bi-check-lg"></i> Publié !';
  setTimeout(() => { btn.disabled = false; btn.innerHTML = '<i class="bi bi-send"></i> Publier'; }, 2500);
});

// Formulaire témoignage
document.getElementById('testimonial-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const resp = await fetch(`/memorial/${MEMORIAL_SLUG}/testimonial`, {
    method: 'POST', body: new FormData(this),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });
  const data = await resp.json();
  if (data.error) { alert(data.error); return; }
  this.reset();
  alert(data.message);
});

// Formulaire livre d'or
document.getElementById('guestbook-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const resp = await fetch(`/memorial/${MEMORIAL_SLUG}/guestbook`, {
    method: 'POST', body: new FormData(this),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });
  const data = await resp.json();
  if (data.error) { alert(data.error); return; }
  this.closest('.memorial-form-card').innerHTML = '<div class="memorial-signed"><i class="bi bi-check-circle-fill"></i> ' + data.message + '</div>';
});

// Gadgets Phase 2
var GADGET_CSRF = '{{ csrf_token("gadget_deposit") }}';
var currentGadget = null;

async function loadWalletGadgets() {
  var container = document.getElementById('gadget-buttons');
  if (!container) return;
  try {
    var res  = await fetch('/api/gadgets/wallet', {headers:{'X-Requested-With':'XMLHttpRequest'}});
    var data = await res.json();
    container.innerHTML = '';
    if (!data.length) {
      container.innerHTML = '<p style="font-size:.8rem;color:var(--em-muted);">Portefeuille vide. <a href="/boutique">Acheter des gadgets</a>.</p>';
      return;
    }
    data.forEach(function(g) {
      var emoji = g.type==='flower'?'🌸':g.type==='candle'?'🕯️':g.type==='dove'?'🕊️':'✨';
      var wrap = document.createElement('div');
      wrap.style.cssText = 'position:relative;display:inline-block;';
      var btn = document.createElement('button');
      btn.className = 'gadget-btn';
      btn.title = g.name+' ('+g.quantity+' restant'+(g.quantity>1?'s':'')+')';
      btn.innerHTML = g.imageUrl?'<img src="'+g.imageUrl+'" style="width:28px;height:28px;object-fit:contain;">':emoji;
      var badge = document.createElement('span');
      badge.id = 'wqty-'+g.id;
      badge.textContent = g.quantity;
      badge.style.cssText = 'position:absolute;top:-5px;right:-5px;background:var(--em-gold);color:white;border-radius:50%;width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700;pointer-events:none;';
      wrap.appendChild(btn); wrap.appendChild(badge); container.appendChild(wrap);
      btn.addEventListener('click', function() { openGadgetModal(g, emoji); });
    });
  } catch(e) { container.innerHTML = '<p style="font-size:.8rem;color:var(--em-muted);">Erreur.</p>'; }
}

async function loadInteractionCounts() {
  try {
    var res  = await fetch('/api/gadgets/interactions/'+MEMORIAL_SLUG);
    var data = await res.json();
    if (data.counts) updateCounts(data.counts);
  } catch(e) {}
}

function updateCounts(c) {
  ['flower','candle','dove'].forEach(function(t) {
    var el = document.getElementById('count-'+t);
    if (!el) return;
    el.querySelector('span').textContent = c[t]||0;
    el.setAttribute('data-active',(c[t]||0)>0?'true':'false');
  });
}

function openGadgetModal(g, emoji) {
  currentGadget = g;
  document.getElementById('gadgetModal__icon').textContent = emoji;
  document.getElementById('gadgetModal__name').textContent = g.name;
  document.getElementById('gadgetModal__remaining').textContent = g.quantity+' dans votre portefeuille';
  var tw = document.getElementById('gadgetModal__textWrap');
  var ti = document.getElementById('gadgetModal__text');
  if (g.allowsText) {
    tw.style.display='block'; ti.value=''; ti.maxLength=g.maxTextLen||80;
    document.getElementById('gadgetModal__textCount').textContent='0/'+(g.maxTextLen||80);
    ti.oninput=function(){document.getElementById('gadgetModal__textCount').textContent=this.value.length+'/'+(g.maxTextLen||80);};
  } else { tw.style.display='none'; }
  document.getElementById('gadgetModal__confirm').onclick = depositGadget;
  document.getElementById('gadgetModal').style.display='flex';
}

function closeGadgetModal() { document.getElementById('gadgetModal').style.display='none'; currentGadget=null; }

async function depositGadget() {
  if (!currentGadget) return;
  var btn = document.getElementById('gadgetModal__confirm');
  btn.disabled=true; btn.textContent='⏳...';
  var fd = new FormData();
  fd.append('_token', GADGET_CSRF);
  fd.append('gadget_id', currentGadget.id);
  var textEl = document.getElementById('gadgetModal__text');
  fd.append('custom_text', textEl ? textEl.value : '');
  var depositedGadget = currentGadget; // Sauvegarder avant closeGadgetModal
  try {
    var res  = await fetch('/boutique/deposer/'+MEMORIAL_SLUG,{method:'POST',body:fd,headers:{'X-Requested-With':'XMLHttpRequest'}});
    var data = await res.json();
    if (data.success) {
      closeGadgetModal();
      var b = document.getElementById('wqty-'+depositedGadget.id);
      if (b) { b.textContent=data.remainingInWallet; if(data.remainingInWallet===0) b.style.display='none'; }
      if (data.counts) updateCounts(data.counts);
      launchAnimation(data.gadgetEmoji, data.customText);
    } else { alert(data.error||'Impossible de déposer.'); }
  } catch(e) { alert('Erreur réseau.'); }
  btn.disabled=false; btn.textContent='Déposer ✨';
}

function launchAnimation(emoji, text) {
  var zone = document.getElementById('gadget-animation-zone');
  if (!zone) return;
  var el = document.createElement('div');
  el.style.cssText='position:absolute;bottom:15%;left:'+(10+Math.random()*80)+'%;font-size:2.5rem;opacity:1;transition:transform 2.5s ease-out,opacity 2s ease-out 0.5s;pointer-events:none;text-align:center;';
  el.innerHTML = emoji+(text?'<div style="font-size:.65rem;background:rgba(0,0,0,.65);color:white;border-radius:8px;padding:.2rem .4rem;margin-top:.2rem;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+text+'</div>':'');
  zone.appendChild(el);
  requestAnimationFrame(function(){requestAnimationFrame(function(){
    el.style.transform='translateY(-'+(250+Math.random()*150)+'px) rotate('+(Math.random()*20-10)+'deg)';
    el.style.opacity='0';
  });});
  setTimeout(function(){el.remove();},3000);
}

document.getElementById('gadgetModal').addEventListener('click',function(e){if(e.target===this)closeGadgetModal();});
var _gStyle=document.createElement('style');
_gStyle.textContent='.memorial-gadgets__counts{display:flex;gap:1rem;margin-bottom:.75rem;flex-wrap:wrap}.gadget-count{display:flex;align-items:center;gap:.3rem;font-size:.85rem;color:var(--em-muted)}.gadget-count span{font-weight:700;color:var(--em-navy)}.gadget-count[data-active="true"] span{color:var(--em-gold)}';
document.head.appendChild(_gStyle);
loadWalletGadgets();
loadInteractionCounts();
