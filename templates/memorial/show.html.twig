{# Modal Upload Médias (modérateurs) #}
{% if isModerator %}
<div id="upload-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:white;border-radius:16px;padding:1.5rem;width:500px;max-width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.3);">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
      <h4 style="margin:0;color:var(--em-navy);font-size:1.1rem;">
        <i class="bi bi-cloud-upload"></i> Ajouter des médias
      </h4>
      <button onclick="closeUploadModal()" style="background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--em-muted);">&times;</button>
    </div>

    {# Zone de dépôt #}
    <div id="pub-dropzone"
         style="border:2px dashed var(--em-stone);border-radius:12px;padding:2rem;text-align:center;
                background:var(--em-cream);cursor:pointer;margin-bottom:1rem;transition:all .2s;"
         ondragover="event.preventDefault();this.style.borderColor='var(--em-gold)';"
         ondragleave="this.style.borderColor='var(--em-stone)';"
         ondrop="handlePubDrop(event)"
         onclick="document.getElementById('pub-file-input').click()">
      <i class="bi bi-cloud-upload" style="font-size:2rem;color:var(--em-gold);display:block;margin-bottom:.5rem;"></i>
      <p style="margin:0 0 .5rem;color:var(--em-muted);font-size:.9rem;">Glissez vos fichiers ici ou cliquez</p>
      <small style="color:var(--em-muted);">Photos JPG/PNG/WebP · Vidéos MP4/WebM · Max 10/100 Mo</small>
      <input type="file" id="pub-file-input" multiple
             accept="image/jpeg,image/png,image/webp,video/mp4,video/webm"
             style="display:none;" onchange="uploadPubFiles(this.files)">
    </div>

    {# Légende #}
    <input type="text" id="pub-caption" placeholder="Légende (optionnelle)"
           maxlength="255"
           style="width:100%;padding:.6rem .8rem;border:1.5px solid var(--em-stone);border-radius:8px;
                  font-size:.875rem;outline:none;box-sizing:border-box;margin-bottom:1rem;">

    {# Progression #}
    <div id="pub-progress-wrap" style="display:none;margin-bottom:1rem;">
      <div style="background:var(--em-cream);border-radius:6px;height:8px;overflow:hidden;">
        <div id="pub-progress-bar" style="height:100%;background:var(--em-gold);width:0%;transition:width .3s;"></div>
      </div>
      <p id="pub-progress-label" style="font-size:.78rem;color:var(--em-muted);margin:.4rem 0 0;text-align:center;"></p>
    </div>

    {# Résultats #}
    <div id="pub-upload-results"></div>

    <div style="display:flex;justify-content:flex-end;gap:.5rem;margin-top:1rem;">
      <button onclick="closeUploadModal()" class="em-btn em-btn--ghost">Fermer</button>
    </div>
