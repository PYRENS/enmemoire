{% extends 'base.html.twig' %}

{% set memorial_theme = page.theme ? page.theme.slug : 'classic-white' %}

{% block title %}{{ page.deceasedFullName }} — {{ page.deceasedBirthDate|date('Y') }}–{{ page.deceasedDeathDate|date('Y') }} — EnMémoire.com{% endblock %}

{% block meta_description %}Page mémorielle de {{ page.deceasedFullName }}, né(e) le {{ page.deceasedBirthDate|date('d/m/Y') }} et décédé(e) le {{ page.deceasedDeathDate|date('d/m/Y') }}.{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('css/memorial.css') }}">
<link rel="stylesheet" href="{{ asset('css/themes/theme-' ~ memorial_theme ~ '.css') }}">

<style>
.memorial-gallery__item-wrap { position: relative; }
.memorial-gallery__mod-actions {
  position: absolute; top: 4px; right: 4px;
  display: flex; gap: 4px; z-index: 10;
}
.mgal-btn {
  width: 28px; height: 28px; border-radius: 6px; border: none;
  display: flex; align-items: center; justify-content: center;
  font-size: .78rem; cursor: pointer; transition: all .2s;
  opacity: .85;
}
.mgal-btn:hover { opacity: 1; transform: scale(1.1); }
.mgal-btn--edit   { background: white; color: var(--em-navy); }
.mgal-btn--delete { background: rgba(185,28,28,.9); color: white; }
</style>

<style>
.em-btn--gold { background: var(--em-gold); color: var(--em-navy); border: none; font-weight: 700; }
.em-btn--gold:hover { background: #b8943f; color: white; }
.em-btn--light { background: rgba(27,43,75,.8); color: white; border: 1.5px solid rgba(255,255,255,.4); font-weight: 500; }
.em-btn--light:hover { background: var(--em-navy); border-color: white; }
.memorial-gallery__item-wrap { position: relative; display: contents; }
.memorial-gallery__mod-actions { position: absolute; top: 4px; right: 4px; display: flex; gap: 4px; z-index: 10; }
.mgal-btn { width: 30px; height: 30px; border-radius: 6px; border: none; display: flex; align-items: center; justify-content: center; font-size: .8rem; cursor: pointer; transition: all .2s; }
.mgal-btn--edit { background: white; color: #1B2B4B; box-shadow: 0 1px 4px rgba(0,0,0,.3); }
.mgal-btn--delete { background: rgba(185,28,28,.9); color: white; }
.mgal-btn:hover { transform: scale(1.1); }
</style>

<style>

.gallery-tabs-wrap {
  display: flex; align-items: center;
  justify-content: space-between; flex-wrap: wrap;
  gap: .5rem; margin-bottom: 1.25rem;
}
.gallery-tabs-wrap .gallery-tabs {
  margin-bottom: 0; border-bottom: none; flex: 1;
  border-bottom: 2px solid var(--em-stone);
}

/* Onglets galerie */
.gallery-tabs {
  display: flex; gap: .5rem; margin-bottom: 1.25rem;
  border-bottom: 2px solid var(--em-stone); padding-bottom: 0;
}
.gallery-tab {
  display: flex; align-items: center; gap: .4rem;
  padding: .6rem 1.25rem; border: none; background: none;
  font-family: var(--font-body); font-size: .9rem; color: var(--em-muted);
  cursor: pointer; border-bottom: 3px solid transparent;
  margin-bottom: -2px; transition: all .2s; border-radius: 6px 6px 0 0;
}
.gallery-tab:hover { color: var(--em-navy); background: var(--em-cream); }
.gallery-tab.active { color: var(--em-navy); font-weight: 600; border-bottom-color: var(--em-gold); }
.gallery-tab__count {
  background: var(--em-cream); color: var(--em-muted);
  font-size: .72rem; padding: 1px 6px; border-radius: 10px;
}
.gallery-tab.active .gallery-tab__count {
  background: var(--em-gold); color: var(--em-navy);
}
.gallery-section { animation: fadeIn .2s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

/* Mobile : onglets scrollables */
@media (max-width: 575px) {
  .gallery-tabs { overflow-x: auto; -webkit-overflow-scrolling: touch; flex-wrap: nowrap; }
  .gallery-tab { white-space: nowrap; flex-shrink: 0; }
}
</style>
<style>.memorial-family-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:.5rem}.memorial-family-header h2{margin:0}.memorial-family-list{display:flex;flex-direction:column;gap:.5rem}.memorial-family-item{display:flex;align-items:center;gap:1rem;padding:.875rem 1rem;border-radius:var(--em-radius);border:1px solid var(--em-stone);text-decoration:none;color:inherit;transition:var(--em-transition)}.memorial-family-item:hover{background:var(--em-cream);border-color:var(--em-gold)}.memorial-family-item__avatar{width:46px;height:46px;border-radius:50%;flex-shrink:0;background:var(--em-navy);color:white;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:600;overflow:hidden;border:2px solid var(--em-stone)}.memorial-family-item__avatar img{width:100%;height:100%;object-fit:cover}.memorial-family-item__info{flex:1;min-width:0}.memorial-family-item__info strong{display:block;color:var(--em-navy);font-size:.9rem}.memorial-family-item__info small{color:var(--em-muted);font-size:.78rem}.memorial-family-item__relation{background:rgba(201,168,76,.15);color:var(--em-navy);font-size:.75rem;font-weight:600;padding:3px 8px;border-radius:8px;flex-shrink:0}</style>
{% endblock %}
{% block body %}

{# ── HERO / EN-TÊTE DE LA PAGE ────────────────────────────── #}
<section class="memorial-hero theme-hero">

  {# Photo de couverture #}
  {% if page.coverPhotoUrl %}
  <div class="memorial-cover" style="background-image:url('{{ page.coverPhotoUrl starts with 'http' ? page.coverPhotoUrl : asset(page.coverPhotoUrl) }}')"></div>
{% elseif page.mainPhotoUrl %}
  <div class="memorial-cover" style="background-image:url('{{ page.mainPhotoUrl starts with 'http' ? page.mainPhotoUrl : asset(page.mainPhotoUrl) }}')"></div>
  {% else %}
  <div class="memorial-cover memorial-cover--default"></div>
  {% endif %}

  <div class="memorial-hero__content container-xl">

    {# Photo du défunt #}
    <div class="memorial-portrait">
      {% if page.mainPhotoUrl %}
        <img src="{{ asset(page.mainPhotoUrl) }}" alt="{{ page.deceasedFullName }}" class="memorial-portrait__img">
      {% else %}
        <div class="memorial-portrait__placeholder">
          <i class="bi bi-person-fill"></i>
        </div>
      {% endif %}
    </div>

    {# Identité #}
    <div class="memorial-identity">
      <h1 class="memorial-name">{{ page.deceasedFullName }}</h1>
      {% if page.deceasedNickname %}
        <p class="memorial-nickname">« {{ page.deceasedNickname }} »</p>
      {% endif %}
      <p class="memorial-dates">
        <span>{{ page.deceasedBirthDate|date('d/m/Y') }}</span>
        <span class="memorial-dates__sep">—</span>
        <span>{{ page.deceasedDeathDate|date('d/m/Y') }}</span>
      </p>
      {% if page.deceasedDeathPlace %}
      <p class="memorial-place">
        <i class="bi bi-geo-alt"></i> {{ page.deceasedDeathPlace }}
      </p>
      {% endif %}
      {% if page.deceasedProfession %}
      <p class="memorial-profession">{{ page.deceasedProfession }}</p>
      {% endif %}
    </div>

    {# Stats rapides #}
    <div class="memorial-stats">
      <div class="memorial-stat">
        <strong>{{ stats.visits ?? 0 }}</strong>
        <span>Visites</span>
      </div>
      <div class="memorial-stat">
        <strong>{{ stats.condolences ?? 0 }}</strong>
        <span>Condoléances</span>
      </div>
      <div class="memorial-stat">
        <strong>{{ stats.photos ?? 0 }}</strong>
        <span>Photos</span>
      </div>
    </div>

    {# Actions rapides #}
    <div class="memorial-hero__actions">
      {% if app.user and not userHasSigned %}
      <button type="button" class="em-btn em-btn--gold" onclick="openTab('guestbook')">
        <i class="bi bi-pen"></i> Signer le livre d'or
      </button>
      {% endif %}
      <button type="button" class="em-btn em-btn--light" onclick="openTab('condolences')">
        <i class="bi bi-chat-heart"></i> Laisser un message
      </button>
      <a href="/qrcode/{{ page.slug }}" class="em-btn em-btn--ghost">
        <i class="bi bi-qr-code"></i> QR Code
      </a>
      {% if isModerator %}
      <a href="{{ path('app_dashboard_memorial', {slug: page.slug}) }}" class="em-btn em-btn--ghost">
        <i class="bi bi-gear"></i> Gérer
      </a>
      {% endif %}
    </div>

  </div>
</section>

{# ── ANNONCES ÉPINGLÉES ───────────────────────────────────── #}
{% if announcements %}
<section class="memorial-announcements container-xl">
  {% for ann in announcements %}
  <div class="memorial-announcement {% if ann.isPinned %}memorial-announcement--pinned{% endif %}">
    <i class="bi bi-megaphone-fill"></i>
    <div>
      <strong>{{ ann.title }}</strong>
      <p>{{ ann.content }}</p>
    </div>
  </div>
  {% endfor %}
</section>
{% endif %}

{# ── CITATION DU DÉFUNT ───────────────────────────────────── #}
{% if page.deceasedQuote %}
<section class="memorial-quote-section">
  <div class="container-xl">
    <blockquote class="memorial-quote theme-quote">
      <span class="memorial-quote__mark">"</span>
      {{ page.deceasedQuote }}
      <span class="memorial-quote__mark">"</span>
      <cite>— {{ page.deceasedFullName }}</cite>
    </blockquote>
  </div>
</section>
{% endif %}

{# ── NAVIGATION ONGLETS ───────────────────────────────────── #}
<div class="memorial-tabs-wrap" id="memorial-tabs">
  <div class="container-xl">
    <div class="memorial-tabs">
      <button class="memorial-tab {{ defaultTab == 'obituary' ? 'active' : '' }}" onclick="openTab('obituary')" id="tab-obituary">
        <i class="bi bi-file-text"></i> Avis de décès
      </button>
      <button class="memorial-tab {{ defaultTab == 'timeline' ? 'active' : '' }}" onclick="openTab('timeline')" id="tab-timeline">
        <i class="bi bi-hourglass-split"></i> Biographie
      </button>
      <button class="memorial-tab" onclick="openTab('gallery')"    id="tab-gallery">
        <i class="bi bi-images"></i> Galerie <span class="tab-count">{{ gallery|length }}</span>
      </button>
      <button class="memorial-tab" onclick="openTab('condolences')" id="tab-condolences">
        <i class="bi bi-chat-heart"></i> Condoléances <span class="tab-count">{{ condolences|length }}</span>
      </button>
      <button class="memorial-tab" onclick="openTab('testimonials')" id="tab-testimonials">
        <i class="bi bi-quote"></i> Témoignages <span class="tab-count">{{ testimonials|length }}</span>
      </button>
      <button class="memorial-tab" onclick="openTab('guestbook')"   id="tab-guestbook">
        <i class="bi bi-book"></i> Livre d'or <span class="tab-count">{{ guestbooks|length }}</span>
      </button>
      <button class="memorial-tab" onclick="openTab('family')" id="tab-family">
        <i class="bi bi-diagram-3"></i> Famille
      </button>
      {% if events %}
      <button class="memorial-tab" onclick="openTab('events')"     id="tab-events">
        <i class="bi bi-calendar-event"></i> Événements
      </button>
      {% endif %}
    </div>
  </div>
</div>

{# ── CONTENU DES ONGLETS ──────────────────────────────────── #}
<div class="container-xl memorial-content">

  {# AVIS DE DÉCÈS #}
  <div class="memorial-panel {{ defaultTab == 'obituary' ? 'active' : '' }}" id="panel-obituary">
    {% if page.obituaryText %}
    <div class="memorial-obituary">
      <h2>Avis de décès</h2>
      <div class="memorial-obituary__text">{{ page.obituaryText|nl2br }}</div>
    </div>
    {% else %}
    <div class="memorial-empty-panel">
      <i class="bi bi-file-text"></i>
      <p>L'avis de décès sera publié prochainement.</p>
    </div>
    {% endif %}

    {# Gadgets / Hommages virtuels #}
    <div class="memorial-gadgets">
      <h3>Déposer un hommage</h3>

      {# Compteurs des gadgets déposés #}
      <div class="memorial-gadgets__counts" id="gadget-counts">
        <span class="gadget-count" id="count-flower" title="Fleurs déposées">🌸 <span>0</span></span>
        <span class="gadget-count" id="count-candle" title="Bougies allumées">🕯️ <span>0</span></span>
        <span class="gadget-count" id="count-dove"   title="Colombes lâchées">🕊️ <span>0</span></span>
      </div>

      {% if app.user %}
      <div class="memorial-gadgets__row" id="gadget-buttons">
        <span style="font-size:.8rem;color:var(--em-muted);">Chargement...</span>
      </div>
      <p class="memorial-gadgets__hint">
        <a href="{{ path('app_gadget_wallet') }}">Mon portefeuille</a>
        &nbsp;·&nbsp;
        <a href="{{ path('app_gadget_shop') }}">Boutique</a>
      </p>
      {% else %}
      <div class="memorial-gadgets__row">
        <button class="gadget-btn" disabled title="Fleur">🌸</button>
        <button class="gadget-btn" disabled title="Bougie">🕯️</button>
        <button class="gadget-btn" disabled title="Colombe">🕊️</button>
      </div>
      <p class="memorial-gadgets__hint">
        <a href="{{ path('app_login') }}">Connectez-vous</a> pour déposer un hommage.
      </p>
      {% endif %}
    </div>
  </div>

{# ── Modal dépôt gadget ── #}
<div id="gadgetModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:white;border-radius:16px;padding:2rem;width:420px;max-width:100%;box-shadow:0 8px 40px rgba(0,0,0,.3);text-align:center;">
    <div id="gadgetModal__icon" style="font-size:3.5rem;margin-bottom:.75rem;"></div>
    <h4 id="gadgetModal__name" style="margin:0 0 .5rem;color:var(--em-navy);font-size:1.1rem;"></h4>
    <p style="font-size:.85rem;color:var(--em-muted);margin-bottom:1.25rem;">Déposer cet hommage sur la page mémorielle</p>
    <div id="gadgetModal__textWrap" style="display:none;margin-bottom:1rem;">
      <input type="text" id="gadgetModal__text"
             style="width:100%;padding:.6rem .875rem;border:1.5px solid #e5e7eb;border-radius:8px;font-size:.875rem;font-family:inherit;"
             placeholder="Message personnel (optionnel)">
      <div id="gadgetModal__textCount" style="font-size:.72rem;color:#9CA3AF;text-align:right;margin-top:.25rem;"></div>
    </div>
    <div style="display:flex;gap:.75rem;justify-content:center;">
      <button onclick="closeGadgetModal()" style="padding:.6rem 1.25rem;border:1.5px solid #e5e7eb;border-radius:8px;background:none;cursor:pointer;font-size:.875rem;">Annuler</button>
      <button id="gadgetModal__confirm" style="padding:.6rem 1.5rem;background:var(--em-gold);color:white;border:none;border-radius:8px;font-weight:700;cursor:pointer;font-size:.875rem;">Déposer ✨</button>
    </div>
    <div id="gadgetModal__remaining" style="font-size:.72rem;color:#9CA3AF;margin-top:.75rem;"></div>
  </div>
</div>

{# ── Zone animation ── #}
<div id="gadget-animation-zone" style="position:fixed;pointer-events:none;z-index:9998;inset:0;overflow:hidden;"></div>

  {# BIOGRAPHIE / LIGNE DE VIE #}
  <div class="memorial-panel {{ defaultTab == 'timeline' ? 'active' : '' }}" id="panel-timeline">
    {% if lifeTimeline %}
    <h2>Biographie</h2>
    <div class="memorial-timeline">
      {% for event in lifeTimeline %}
      <div class="memorial-timeline__item">
        <div class="memorial-timeline__date">{{ event.eventDate|date('Y') }}</div>
        <div class="memorial-timeline__dot"></div>
        <div class="memorial-timeline__content">
          <h4>{{ event.title }}</h4>
          {% if event.description %}<p>{{ event.description }}</p>{% endif %}
          {% if event.locationName %}<small><i class="bi bi-geo-alt"></i> {{ event.locationName }}</small>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="memorial-empty-panel">
      <i class="bi bi-hourglass-split"></i>
      <p>La biographie sera complétée prochainement.</p>
    </div>
    {% endif %}
  </div>

  {# GALERIE #}
  <div class="memorial-panel" id="panel-gallery">

    {% set photos = gallery|filter(m => m.type != 'video') %}
    {% set videos = gallery|filter(m => m.type == 'video') %}

    {% if gallery is empty %}
    <div class="memorial-empty-panel">
      <i class="bi bi-images"></i>
      <p>La galerie sera alimentée prochainement.</p>
    </div>
    {% else %}

    {# Onglets galerie + bouton upload modérateur #}
    <div class="gallery-tabs-wrap">
      <div class="gallery-tabs">
        <button class="gallery-tab active" onclick="switchGalleryTab('photos', this)">
          <i class="bi bi-images"></i> Photos
          <span class="gallery-tab__count">{{ photos|length }}</span>
        </button>
        {% if videos is not empty %}
        <button class="gallery-tab" onclick="switchGalleryTab('videos', this)">
          <i class="bi bi-play-circle"></i> Vidéos
          <span class="gallery-tab__count">{{ videos|length }}</span>
        </button>
        {% endif %}
      </div>
      {% if isModerator %}
      <button onclick="openUploadModal()" class="em-btn em-btn--primary em-btn--sm">
        <i class="bi bi-cloud-upload"></i> Ajouter des médias
      </button>
      {% endif %}
    </div>

    {# Section Photos #}
    <div class="gallery-section" id="gallery-photos">
      {% if photos is not empty %}
      <div class="memorial-gallery">
        {% for media in photos %}
        <div style="position:relative;" id="gallery-item-{{ media.id }}">
          <a href="javascript:void(0)" class="memorial-gallery__item"
             data-lightbox="gallery"
             data-url="{{ media.url starts with 'http' ? media.url : asset(media.url) }}"
             data-caption="{{ media.caption ?? '' }}"
             data-type="photo"
             onclick="openLightbox(event,this)">
            <img src="{{ (media.thumbnailUrl ?? media.url) starts with 'http' ? (media.thumbnailUrl ?? media.url) : asset(media.thumbnailUrl ?? media.url) }}"
                 alt="{{ media.caption ?? 'Photo de ' ~ page.deceasedFullName }}"
                 loading="lazy">
            {% if media.caption %}
            <div class="memorial-gallery__caption">{{ media.caption }}</div>
            {% endif %}
          </a>
          {% if isModerator %}
          <div class="memorial-gallery__mod-actions">
            <button onclick="editGalleryCaption({{ media.id }}, '{{ media.caption|default('')|e('js') }}')"
                    class="mgal-btn mgal-btn--edit" title="Modifier la légende">
              <i class="bi bi-pencil"></i>
            </button>
            <button onclick="deleteGalleryItem({{ media.id }})"
                    class="mgal-btn mgal-btn--delete" title="Supprimer">
              <i class="bi bi-trash"></i>
            </button>
          </div>
          <span class="mgal-csrf-delete" data-id="{{ media.id }}" style="display:none;">{{ csrf_token('media_delete_' ~ media.id) }}</span>
          <span class="mgal-csrf-caption" data-id="{{ media.id }}" style="display:none;">{{ csrf_token('media_caption_' ~ media.id) }}</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="memorial-empty-panel">
        <i class="bi bi-images"></i>
        <p>Aucune photo pour l'instant.</p>
      </div>
      {% endif %}
    </div>

    {# Section Vidéos #}
    {% if videos is not empty %}
    <div class="gallery-section" id="gallery-videos" style="display:none;">
      <div class="memorial-gallery">
        {% for media in videos %}
        <div style="position:relative;" id="gallery-item-{{ media.id }}">
          <a href="javascript:void(0)" class="memorial-gallery__item"
             data-lightbox="gallery"
             data-url="{{ media.url starts with 'http' ? media.url : asset(media.url) }}"
             data-caption="{{ media.caption ?? '' }}"
             data-type="video"
             onclick="openLightbox(event,this)">
            <div style="position:relative;width:100%;height:100%;min-height:120px;background:#1a1a2e;display:flex;align-items:center;justify-content:center;">
              {% if media.thumbnailUrl and media.thumbnailUrl starts with 'http' %}
                <img src="{{ media.thumbnailUrl }}" alt="" loading="lazy"
                     style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.6;">
              {% endif %}
              <span style="position:relative;font-size:3rem;color:white;text-shadow:0 2px 12px rgba(0,0,0,.8);z-index:1;">▶</span>
            </div>
            {% if media.caption %}
            <div class="memorial-gallery__caption">{{ media.caption }}</div>
            {% endif %}
          </a>
          {% if isModerator %}
          <div class="memorial-gallery__mod-actions">
            <button onclick="editGalleryCaption({{ media.id }}, '{{ media.caption|default('')|e('js') }}')"
                    class="mgal-btn mgal-btn--edit" title="Modifier la légende">
              <i class="bi bi-pencil"></i>
            </button>
            <button onclick="deleteGalleryItem({{ media.id }})"
                    class="mgal-btn mgal-btn--delete" title="Supprimer">
              <i class="bi bi-trash"></i>
            </button>
          </div>
          <span class="mgal-csrf-delete" data-id="{{ media.id }}" style="display:none;">{{ csrf_token('media_delete_' ~ media.id) }}</span>
          <span class="mgal-csrf-caption" data-id="{{ media.id }}" style="display:none;">{{ csrf_token('media_caption_' ~ media.id) }}</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% endif %}

  </div>

  {# CONDOLÉANCES #}
  <div class="memorial-panel" id="panel-condolences">
    <h2>Condoléances</h2>

    {% if app.user %}
    <div class="memorial-form-card" id="condolence-form-wrap">
      <h3>Laisser un message de condoléance</h3>
      <form id="condolence-form">
        <input type="hidden" name="_token" value="{{ csrf_token('condolence_' ~ page.id) }}">
        <textarea name="message" class="memorial-textarea"
                  placeholder="Vos pensées et condoléances…" rows="4" required maxlength="2000"></textarea>
        <div class="memorial-form-footer">
          <label class="memorial-check">
            <input type="checkbox" name="anonymous"> Publier anonymement
          </label>
          <button type="submit" class="em-btn em-btn--primary" id="condolence-submit">
            <i class="bi bi-send"></i> Publier
          </button>
        </div>
      </form>
    </div>
    {% else %}
    <div class="memorial-login-prompt">
      <a href="{{ path('app_login') }}" class="em-btn em-btn--primary">
        <i class="bi bi-person"></i> Se connecter pour laisser une condoléance
      </a>
    </div>
    {% endif %}

    <div class="memorial-messages" id="condolences-list">
      {% for c in condolences %}
      {% include 'memorial/partials/_condolence_item.html.twig' with {condolence: c} %}
      {% else %}
      <div class="memorial-empty-panel">
        <i class="bi bi-chat-heart"></i>
        <p>Soyez le premier à laisser un message de condoléance.</p>
      </div>
      {% endfor %}
    </div>
  </div>

  {# TÉMOIGNAGES #}
  <div class="memorial-panel" id="panel-testimonials">
    <h2>Témoignages</h2>

    {% if app.user %}
    <div class="memorial-form-card">
      <h3>Partager un souvenir</h3>
      <form id="testimonial-form">
        <input type="hidden" name="_token" value="{{ csrf_token('testimonial_' ~ page.id) }}">
        <input type="text" name="title" class="memorial-input" placeholder="Titre (optionnel)" maxlength="255">
        <input type="text" name="relation" class="memorial-input"
               placeholder="Votre lien avec {{ page.deceasedFirstName }} (ex: ami, collègue…)" maxlength="100">
        <textarea name="content" class="memorial-textarea"
                  placeholder="Partagez votre souvenir…" rows="5" required maxlength="3000"></textarea>
        <div class="memorial-form-footer">
          <button type="submit" class="em-btn em-btn--primary">
            <i class="bi bi-quote"></i> Partager
          </button>
        </div>
      </form>
    </div>
    {% endif %}

    <div class="memorial-messages">
      {% for t in testimonials %}
      <div class="memorial-testimonial">
        <div class="memorial-testimonial__header">
          <div class="memorial-testimonial__avatar">{{ t.user.firstName|first|upper }}</div>
          <div>
            <strong>{{ t.user.fullName }}</strong>
            {% if t.relationToDeceased %}<small> · {{ t.relationToDeceased }}</small>{% endif %}
            <div class="memorial-msg-date">{{ t.createdAt|date('d/m/Y') }}</div>
          </div>
        </div>
        {% if t.title %}<h4 class="memorial-testimonial__title">{{ t.title }}</h4>{% endif %}
        <p class="memorial-testimonial__content">{{ t.content|nl2br }}</p>
      </div>
      {% else %}
      <div class="memorial-empty-panel">
        <i class="bi bi-quote"></i>
        <p>Partagez vos souvenirs de {{ page.deceasedFirstName }}.</p>
      </div>
      {% endfor %}
    </div>
  </div>

  {# LIVRE D'OR #}
  <div class="memorial-panel" id="panel-guestbook">
    <h2>Livre d'or</h2>

    {% if app.user and not userHasSigned %}
    <div class="memorial-form-card">
      <h3>Signer le livre d'or</h3>
      <form id="guestbook-form">
        <input type="hidden" name="_token" value="{{ csrf_token('guestbook_' ~ page.id) }}">
        <textarea name="signature_text" class="memorial-textarea"
                  placeholder="Votre message de soutien (optionnel)…" rows="3" maxlength="500"></textarea>
        <div class="memorial-form-footer">
          <button type="submit" class="em-btn em-btn--primary">
            <i class="bi bi-pen"></i> Signer
          </button>
        </div>
      </form>
    </div>
    {% elseif userHasSigned %}
    <div class="memorial-signed mb-3" style="padding-left:10px">
      <i class="bi bi-check-circle-fill"></i> Vous avez signé ce livre d'or.
    </div>
    {% endif %}

    <div class="memorial-guestbook">
      {% for g in guestbooks %}
      <div class="memorial-guestbook__entry">
        <div class="memorial-guestbook__avatar">{{ g.user.firstName|first|upper }}</div>
        <div class="memorial-guestbook__content">
          <strong>{{ g.user.fullName }}</strong>
          <span class="memorial-guestbook__date">· {{ g.signedAt|date('d/m/Y') }}</span>
          {% if g.signatureText %}<p>{{ g.signatureText }}</p>{% endif %}
        </div>
      </div>
      {% else %}
      <div class="memorial-empty-panel">
        <i class="bi bi-book"></i>
        <p>Le livre d'or attend vos signatures.</p>
      </div>
      {% endfor %}
    </div>
  </div>

  {# ÉVÉNEMENTS #}
  {% if events %}
  <div class="memorial-panel" id="panel-events">
    <h2>Événements</h2>
    <div class="memorial-events">
      {% for event in events %}
      <a href="{{ path('app_memorial_event_show', {slug: page.slug, eventId: event.id}) }}"
         class="memorial-event-card" style="text-decoration:none;display:flex;">
        <div class="memorial-event-card__date">
          <span class="memorial-event-card__day">{{ event.eventDate|date('d') }}</span>
          <span class="memorial-event-card__month">{{ event.eventDate|date('M')|upper }}</span>
        </div>
        <div class="memorial-event-card__info">
          <h4>{{ event.title }}</h4>
          <p>{{ event.eventDate|date('H:i') }}
            {% if event.locationName %} · <i class="bi bi-geo-alt"></i> {{ event.locationName }}{% endif %}
          </p>
          {% if event.description %}<p class="text-muted">{{ event.description }}</p>{% endif %}
        </div>
        {% if event.isLive %}
        <span class="memorial-live-badge"><i class="bi bi-broadcast"></i> Live</span>
        {% endif %}
        <div class="ms-auto d-flex align-items-center ps-3">
          <span class="em-btn em-btn--outline em-btn--sm">
            <i class="bi bi-arrow-right"></i>
          </span>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# FAMILLE #}
  <div class="memorial-panel" id="panel-family">
    {% if familyConnections is defined and familyConnections is not empty %}

    {# Switcher graphique / liste #}
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:.5rem;">
      <h2 style="margin:0;">Arbre familial</h2>
      <div style="display:flex;gap:.4rem;">
        <button onclick="switchFamilyView('list')" id="fam-btn-list" class="em-btn em-btn--primary em-btn--sm">
          <i class="bi bi-list-ul"></i> Liste
        </button>
        <button onclick="switchFamilyView('graph')" id="fam-btn-graph" class="em-btn em-btn--ghost em-btn--sm">
          <i class="bi bi-diagram-3"></i> Graphique
        </button>
        <a href="{{ path('app_family_tree', {slug: page.slug}) }}" 
           class="em-btn em-btn--ghost em-btn--sm">
          <i class="bi bi-arrows-fullscreen"></i>
        </a>
      </div>
    </div>

    {# Vue graphique #}
    <div id="fam-view-graph" style="display:none;background:var(--em-cream);border-radius:var(--em-radius-lg);overflow:hidden;position:relative;width:100%;">
      <svg id="fam-svg" width="100%" height="500" style="display:block;"></svg>
    </div>

    {# Vue liste #}
    <div id="fam-view-list">
      <div class="memorial-family-list">
        {% for conn in familyConnections %}
          {% set isCentral = conn.memorialFrom.id == page.id %}
          {% set relative  = isCentral ? conn.memorialTo : conn.memorialFrom %}
          {% set relation  = isCentral ? conn.relationFrom : conn.relationTo %}
          <a href="{{ path('app_memorial_show', {slug: relative.slug}) }}" class="memorial-family-item">
            <div class="memorial-family-item__avatar">
              {% if relative.mainPhotoUrl %}
                <img src="{{ relative.mainPhotoUrl starts with 'http' ? relative.mainPhotoUrl : asset(relative.mainPhotoUrl) }}"
                     alt="{{ relative.deceasedFullName }}">
              {% else %}
                {{ relative.deceasedFirstName|first|upper }}
              {% endif %}
            </div>
            <div class="memorial-family-item__info">
              <strong>{{ relative.deceasedFullName }}</strong>
              <small>{{ relative.deceasedBirthDate|date('Y') }} – {{ relative.deceasedDeathDate|date('Y') }}</small>
            </div>
            <span class="memorial-family-item__relation">{{ relation }}</span>
          </a>
        {% endfor %}
      </div>
    </div>

    {% else %}
    <div class="memorial-empty-panel">
      <i class="bi bi-diagram-3"></i>
      <p>L'arbre familial n'a pas encore été constitué.</p>
    </div>
    {% endif %}
  </div>

</div>{# /.container #}

{# ── PIED DE PAGE MÉMORIEL ────────────────────────────────── #}
<footer class="memorial-footer theme-footer">
  <div class="container-xl">
    <div class="memorial-footer__content">
      <div class="memorial-footer__qr">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=80x80&data={{ (app.request.schemeAndHttpHost ~ '/memorial/' ~ page.slug)|url_encode }}&ecc=H"
             alt="Page QR Code" class="memorial-footer__qr-link-icon">
        <div>
          <strong>{{ page.pageCode }}</strong>
          <a href="/qrcode/{{ page.slug }}" class="memorial-footer__qr-link">
            <i class="bi bi-qr-code"></i> Télécharger le QR Code
          </a>
        </div>
      </div>
      <div class="memorial-footer__share">
        <strong>Partager cette page</strong>
        <div class="memorial-footer__share-btns">
          <a href="https://wa.me/?text={{ ('En mémoire de ' ~ page.deceasedFullName ~ ' : ' ~ app.request.uri)|url_encode }}"
             target="_blank" class="memorial-share-btn memorial-share-btn--whatsapp">
            <i class="bi bi-whatsapp"></i> WhatsApp
          </a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ app.request.uri|url_encode }}"
             target="_blank" class="memorial-share-btn memorial-share-btn--facebook">
            <i class="bi bi-facebook"></i> Facebook
          </a>
          <button onclick="copyPageLink()" class="memorial-share-btn memorial-share-btn--copy" id="copy-page-btn">
            <i class="bi bi-link-45deg"></i> Copier le lien
          </button>
        </div>
      </div>
    </div>
  </div>
</footer>


