{% block javascripts %}
<script src="{{ asset('js/memorial.js') }}"></script>
<script>
const MEMORIAL_SLUG = '{{ page.slug }}';

// Onglets
function openTab(name) {
  document.querySelectorAll('.memorial-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.memorial-tab').forEach(t => t.classList.remove('active'));
  const panel = document.getElementById('panel-' + name);
  const tab   = document.getElementById('tab-' + name);
  if (panel) panel.classList.add('active');
  if (tab)   tab.classList.add('active');
  document.getElementById('memorial-tabs').scrollIntoView({behavior: 'smooth', block: 'nearest'});
}

// Copier le lien
function copyPageLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    const btn = document.getElementById('copy-page-btn');
    btn.innerHTML = '<i class="bi bi-check-lg"></i> Copié !';
    setTimeout(() => { btn.innerHTML = '<i class="bi bi-link-45deg"></i> Copier le lien'; }, 2000);
  });
}

// Formulaire condoléance
document.getElementById('condolence-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn  = document.getElementById('condolence-submit');
  btn.disabled = true;
  btn.innerHTML = '<i class="bi bi-hourglass"></i> Envoi…';

  const resp = await fetch(`/memorial/${MEMORIAL_SLUG}/condolence`, {
    method: 'POST',
    body:   new FormData(this),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });
  const data = await resp.json();

  if (data.error) {
    alert(data.error);
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-send"></i> Publier';
    return;
  }

  if (data.html) {
    document.getElementById('condolences-list').insertAdjacentHTML('afterbegin', data.html);
  }

  this.reset();
  btn.innerHTML = '<i class="bi bi-check-lg"></i> Publié !';
  setTimeout(() => { btn.disabled = false; btn.innerHTML = '<i class="bi bi-send"></i> Publier'; }, 2500);
});

// Formulaire témoignage
document.getElementById('testimonial-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const resp = await fetch(`/memorial/${MEMORIAL_SLUG}/testimonial`, {
    method: 'POST', body: new FormData(this),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });
  const data = await resp.json();
  if (data.error) { alert(data.error); return; }
  this.reset();
  alert(data.message);
});

// Formulaire livre d'or
document.getElementById('guestbook-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();
  const resp = await fetch(`/memorial/${MEMORIAL_SLUG}/guestbook`, {
    method: 'POST', body: new FormData(this),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });
  const data = await resp.json();
  if (data.error) { alert(data.error); return; }
  this.closest('.memorial-form-card').innerHTML = '<div class="memorial-signed"><i class="bi bi-check-circle-fill"></i> ' + data.message + '</div>';
});

// Gadgets
document.querySelectorAll('.gadget-btn').forEach(btn => {
  btn.addEventListener('click', async function() {
    const action = this.dataset.action;
    const form   = new FormData();
    form.append('_token', '{{ csrf_token("gadget_deposit") }}');
    form.append('gadget_id', '1'); // TODO: sélecteur gadget dynamique
    form.append('action', action);

    const resp = await fetch(`/boutique/deposer/${MEMORIAL_SLUG}`, {
      method: 'POST', body: form,
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    const data = await resp.json();
    if (data.success) {
      this.style.transform = 'scale(1.4)';
      setTimeout(() => { this.style.transform = ''; }, 400);
    } else {
      alert(data.error || 'Gadget indisponible.');
    }
  });
});
</script>
<script>
var _lbItems=[],_lbIdx=0;
function openLightbox(e,el){e.preventDefault();_lbItems=Array.from(document.querySelectorAll('[data-lightbox="gallery"]')).map(function(a){return{url:a.dataset.url,caption:a.dataset.caption,type:a.dataset.type};});_lbIdx=Array.from(document.querySelectorAll('[data-lightbox="gallery"]')).indexOf(el);_showLb(_lbIdx);document.getElementById('lightbox').style.display='flex';}
function closeLightbox(){document.getElementById('lightbox').style.display='none';var v=document.getElementById('lightbox-video');v.pause();v.src='';}
function lightboxNav(d){_lbIdx=(_lbIdx+d+_lbItems.length)%_lbItems.length;_showLb(_lbIdx);}
function _showLb(i){var item=_lbItems[i],img=document.getElementById('lightbox-img'),vid=document.getElementById('lightbox-video');if(item.type==='video'){img.style.display='none';vid.style.display='block';vid.src=item.url;}else{vid.style.display='none';vid.pause();img.style.display='block';img.src=item.url;img.alt=item.caption;}document.getElementById('lightbox-caption').textContent=item.caption||'';document.getElementById('lightbox-counter').textContent=(i+1)+' / '+_lbItems.length;}
document.addEventListener('keydown',function(e){if(document.getElementById('lightbox').style.display==='none')return;if(e.key==='Escape')closeLightbox();if(e.key==='ArrowLeft')lightboxNav(-1);if(e.key==='ArrowRight')lightboxNav(1);});
document.getElementById('lightbox').addEventListener('click',function(e){if(e.target===this)closeLightbox();});

// Gestion galerie modérateur
var MEMORIAL_SLUG_MOD = '{{ page.slug }}';

async function deleteGalleryItem(id) {
  if (!confirm('Supprimer ce média définitivement ?')) return;
  var csrf = document.querySelector(`.mgal-csrf-delete[data-id="${id}"]`)?.textContent?.trim();
  var form = new FormData(); form.append('_token', csrf);
  var resp = await fetch(`/memorial/${MEMORIAL_SLUG_MOD}/media/galerie/${id}/delete`, {method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}});
  var data = await resp.json();
  if (data.success) { document.getElementById(`gallery-item-${id}`)?.remove(); }
  else alert(data.error || 'Erreur');
}

function editGalleryCaption(id, current) {
  var caption = prompt('Modifier la légende :', current);
  if (caption === null) return;
  var csrf = document.querySelector(`.mgal-csrf-caption[data-id="${id}"]`)?.textContent?.trim();
  var form = new FormData(); form.append('_token', csrf); form.append('caption', caption);
  fetch(`/memorial/${MEMORIAL_SLUG_MOD}/media/galerie/${id}/caption`, {method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}})
    .then(r => r.json()).then(data => {
      if (data.success) {
        var cap = document.querySelector(`#gallery-item-${id} .memorial-gallery__caption`);
        if (caption) {
          if (cap) cap.textContent = caption;
          else {
            var newCap = document.createElement('div');
            newCap.className = 'memorial-gallery__caption';
            newCap.textContent = caption;
            document.querySelector(`#gallery-item-${id} .memorial-gallery__item`)?.appendChild(newCap);
          }
        } else if (cap) cap.remove();
      }
    });
}

</script>
