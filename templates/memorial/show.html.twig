var PUB_SLUG = '{{ page.slug }}';
var PUB_CSRF = '{{ csrf_token("media_gallery_" ~ page.id) }}';

function openUploadModal() {
  document.getElementById('upload-modal').style.display = 'flex';
  document.getElementById('pub-caption').value = '';
  document.getElementById('pub-upload-results').innerHTML = '';
  document.getElementById('pub-progress-wrap').style.display = 'none';
}
function closeUploadModal() {
  document.getElementById('upload-modal').style.display = 'none';
}
document.getElementById('upload-modal')?.addEventListener('click', function(e){
  if (e.target === this) closeUploadModal();
});

function handlePubDrop(e) {
  e.preventDefault();
  document.getElementById('pub-dropzone').style.borderColor = 'var(--em-stone)';
  uploadPubFiles(e.dataTransfer.files);
}

async function uploadPubFiles(files) {
  if (!files || files.length === 0) return;
  var caption = document.getElementById('pub-caption').value.trim();
  var results = document.getElementById('pub-upload-results');
  var progressWrap = document.getElementById('pub-progress-wrap');
  var progressBar  = document.getElementById('pub-progress-bar');
  var progressLabel = document.getElementById('pub-progress-label');

  progressWrap.style.display = 'block';
  results.innerHTML = '';

  for (var i = 0; i < files.length; i++) {
    var file = files[i];
    progressLabel.textContent = 'Upload ' + (i+1) + '/' + files.length + ' : ' + file.name;
    progressBar.style.width = Math.round((i / files.length) * 100) + '%';

    var form = new FormData();
    form.append('files', file);
    form.append('caption', caption);
    form.append('_token', PUB_CSRF);

    try {
      var resp = await fetch('/memorial/' + PUB_SLUG + '/media/galerie', {
        method: 'POST', body: form, headers: {'X-Requested-With': 'XMLHttpRequest'}
      });
      var data = await resp.json();

      if (data.success && data.uploaded.length > 0) {
        data.uploaded.forEach(function(m) {
          addToPublicGallery(m);
          // Feedback visuel
          var div = document.createElement('div');
          div.style.cssText = 'color:var(--em-success);font-size:.8rem;margin:.2rem 0;';
          div.innerHTML = '<i class="bi bi-check-circle"></i> ' + file.name + ' uploadé';
          results.appendChild(div);
        });
      } else if (data.errors && data.errors.length > 0) {
        var div = document.createElement('div');
        div.style.cssText = 'color:var(--em-danger);font-size:.8rem;margin:.2rem 0;';
        div.innerHTML = '<i class="bi bi-x-circle"></i> ' + (data.errors[0] || 'Erreur');
        results.appendChild(div);
      }
    } catch(e) {
      var div = document.createElement('div');
      div.style.cssText = 'color:var(--em-danger);font-size:.8rem;';
      div.textContent = 'Erreur réseau : ' + file.name;
      results.appendChild(div);
    }
  }

  progressBar.style.width = '100%';
  progressLabel.textContent = 'Terminé !';
  setTimeout(function(){ progressWrap.style.display = 'none'; }, 2000);
}

function addToPublicGallery(media) {
  var grid = document.getElementById('gallery-photos');
  if (!grid) return;
  var galleryDiv = grid.querySelector('.memorial-gallery');
  if (!galleryDiv) {
    // Supprimer le panel vide si présent
    var empty = grid.querySelector('.memorial-empty-panel');
    if (empty) empty.remove();
    galleryDiv = document.createElement('div');
    galleryDiv.className = 'memorial-gallery';
    grid.appendChild(galleryDiv);
  }

  var wrap = document.createElement('div');
  wrap.style.position = 'relative';
  wrap.id = 'gallery-item-' + media.id;

  var url = media.url;
  var thumb = media.thumb || url;

  if (media.type === 'video') {
    wrap.innerHTML = '<a href="javascript:void(0)" class="memorial-gallery__item" data-lightbox="gallery" data-url="'+url+'" data-caption="'+(media.caption||'')+'" data-type="video" onclick="openLightbox(event,this)"><div style="position:relative;width:100%;height:100%;min-height:120px;background:#1a1a2e;display:flex;align-items:center;justify-content:center;"><span style="font-size:3rem;color:white;">▶</span></div></a>';
    // Ajouter à l'onglet vidéos
    var videoGrid = document.getElementById('gallery-videos');
    if (videoGrid) {
      var vg = videoGrid.querySelector('.memorial-gallery');
      if (!vg) { vg = document.createElement('div'); vg.className = 'memorial-gallery'; videoGrid.appendChild(vg); }
      vg.appendChild(wrap);
    }
  } else {
    wrap.innerHTML = '<a href="javascript:void(0)" class="memorial-gallery__item" data-lightbox="gallery" data-url="'+url+'" data-caption="'+(media.caption||'')+'" data-type="photo" onclick="openLightbox(event,this)"><img src="'+thumb+'" alt="'+(media.caption||'')+'" loading="lazy"></a>';
    galleryDiv.insertBefore(wrap, galleryDiv.firstChild);
  }

  // Boutons modérateurs
  var actions = document.createElement('div');
  actions.className = 'memorial-gallery__mod-actions';
  var caption = media.caption || '';
  actions.innerHTML = '<button onclick="editGalleryCaption(' + media.id + ', &quot;' + caption.replace(/"/g, '') + '&quot;)" class="mgal-btn mgal-btn--edit" title="Modifier"><i class="bi bi-pencil"></i></button>'
    + '<button onclick="deleteGalleryItem(' + media.id + ')" class="mgal-btn mgal-btn--delete" title="Supprimer"><i class="bi bi-trash"></i></button>';
  wrap.appendChild(actions);
}
</script>

{# D3 famille #}
<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<script>
// Données arbre famille
var FAM_DATA = {
  nodes: [
    { id: {{ page.id }}, label: '{{ page.deceasedFullName|e('js') }}', slug: '{{ page.slug }}',
      dates: '{{ page.deceasedBirthDate|date('Y') }}–{{ page.deceasedDeathDate|date('Y') }}',
      photo: '{{ page.mainPhotoUrl ?? '' }}', isCentral: true }{% if familyConnections is defined and familyConnections is not empty %},
    {% for conn in familyConnections %}
      {% set rel = conn.memorialFrom.id == page.id ? conn.memorialTo : conn.memorialFrom %}
      { id: {{ rel.id }}, label: '{{ rel.deceasedFullName|e('js') }}', slug: '{{ rel.slug }}',
        dates: '{{ rel.deceasedBirthDate|date('Y') }}–{{ rel.deceasedDeathDate|date('Y') }}',
        photo: '{{ rel.mainPhotoUrl ?? '' }}', isCentral: false }{% if not loop.last %},{% endif %}
    {% endfor %}
    {% endif %}
  ],
  edges: [{% if familyConnections is defined and familyConnections is not empty %}
    {% for conn in familyConnections %}
      { from: {{ conn.memorialFrom.id }}, to: {{ conn.memorialTo.id }},
        relFrom: '{{ conn.relationFrom|e('js') }}', relTo: '{{ conn.relationTo|e('js') }}' }{% if not loop.last %},{% endif %}
    {% endfor %}
    {% endif %}
  ]
};

var _famSvg=null, _famZoom=null, _famSim=null, _famInit=false;

function switchFamilyView(view) { if(view==='graph'){var w=document.getElementById('fam-view-graph').parentElement.clientWidth||800;document.getElementById('fam-svg').setAttribute('width',w);}
  document.getElementById('fam-view-graph').style.display = view==='graph' ? 'block' : 'none';
  document.getElementById('fam-view-list').style.display  = view==='list'  ? 'block' : 'none';
  document.getElementById('fam-btn-graph').className = 'em-btn em-btn--sm ' + (view==='graph' ? 'em-btn--primary' : 'em-btn--ghost');
  document.getElementById('fam-btn-list').className  = 'em-btn em-btn--sm ' + (view==='list'  ? 'em-btn--primary' : 'em-btn--ghost');
  if (view==='graph' && !_famInit) { setTimeout(initFamGraph, 80); _famInit=true; }
}

// Init quand l'onglet famille est ouvert
var _origOpenTab = typeof openTab !== 'undefined' ? openTab : null;
document.addEventListener('DOMContentLoaded', function(){
  var origOpenTab = window.openTab;
  window.openTab = function(name) {
    origOpenTab(name);
    if (name==='family' && !_famInit) { setTimeout(initFamGraph, 100); _famInit=true; }
  };
});

function initFamGraph() {
  if (!FAM_DATA.nodes.length) return;
  var svgEl = document.getElementById('fam-svg');
  if (!svgEl) return;
  var W = Math.max(svgEl.getBoundingClientRect().width, svgEl.parentElement.getBoundingClientRect().width, svgEl.offsetParent ? svgEl.offsetParent.clientWidth : 0, 600);
  var H = 500;
  svgEl.setAttribute('width', W);
  d3.select('#fam-svg').selectAll('*').remove();
  _famSvg = d3.select('#fam-svg');
  _famZoom = d3.zoom().scaleExtent([0.2,4]).on('zoom', function(e){ gFam.attr('transform', e.transform); });
  _famSvg.call(_famZoom);
  var gFam = _famSvg.append('g');
  var nodes = FAM_DATA.nodes.map(function(d){ return Object.assign({},d); });
  var edges = FAM_DATA.edges.map(function(d){ return {source:String(d.from),target:String(d.to),relFrom:d.relFrom,relTo:d.relTo}; });
  var cx=W/2, cy=H/2;
  nodes.forEach(function(n,i){
    n.x = n.isCentral ? cx : cx+200*Math.cos(2*Math.PI*i/Math.max(nodes.length,1));
    n.y = n.isCentral ? cy : cy+140*Math.sin(2*Math.PI*i/Math.max(nodes.length,1));
  });
  var defs=_famSvg.append('defs');
  nodes.forEach(function(n){
    if(n.photo){
      defs.append('clipPath').attr('id','fclip-'+n.id)
        .append('circle').attr('cx',0).attr('cy',0).attr('r',n.isCentral?34:24);
    }
  });
  var lnk = gFam.append('g').selectAll('line').data(edges).enter().append('line')
    .attr('stroke','#C9A84C').attr('stroke-width',2).attr('opacity',0.7);
  var lbl = gFam.append('g').selectAll('text').data(edges).enter().append('text')
    .attr('text-anchor','middle').attr('font-size','9px').attr('fill','#9CA3AF')
    .text(function(d){ return d.relFrom+'/'+d.relTo; });
  var ndG = gFam.append('g').selectAll('g').data(nodes).enter().append('g')
    .style('cursor','pointer')
    .on('click',function(e,d){ if(!e.defaultPrevented) window.location.href='/memorial/'+d.slug; })
    .call(d3.drag()
      .on('start',function(e,d){ if(!e.active)_famSim.alphaTarget(0.3).restart(); d.fx=d.x;d.fy=d.y; })
      .on('drag', function(e,d){ d.fx=e.x;d.fy=e.y; })
      .on('end',  function(e,d){ if(!e.active)_famSim.alphaTarget(0); d.fx=d.x;d.fy=d.y; })
    );
  ndG.append('circle')
    .attr('r',function(d){ return d.isCentral?36:26; })
    .attr('fill',function(d){ return d.isCentral?'#F8F4EE':'white'; })
    .attr('stroke',function(d){ return d.isCentral?'#C9A84C':'#1B2B4B'; })
    .attr('stroke-width',function(d){ return d.isCentral?3:2; });
  ndG.each(function(d){
    var n=d3.select(this),r=d.isCentral?34:24;
    if(d.photo){
      var url=d.photo.startsWith('http')?d.photo:'/'+d.photo.replace(/^\//,'');
      n.append('image').attr('href',url).attr('x',-r).attr('y',-r).attr('width',r*2).attr('height',r*2)
        .attr('preserveAspectRatio','xMidYMid slice').attr('clip-path','url(#fclip-'+d.id+')');
    } else {
      n.append('text').attr('text-anchor','middle').attr('dy','0.35em').attr('font-size',d.isCentral?'1.1rem':'0.9rem').attr('fill','#1B2B4B')
        .text(d.label.split(' ').slice(0,2).map(function(w){return w[0];}).join('').toUpperCase());
    }
  });
  ndG.append('text').attr('text-anchor','middle').attr('y',function(d){return d.isCentral?50:38;})
    .attr('font-size','11px').attr('font-weight','600').attr('fill','#1B2B4B')
    .text(function(d){ return d.label.split(' ')[0]; });
  ndG.append('text').attr('text-anchor','middle').attr('y',function(d){return d.isCentral?63:50;})
    .attr('font-size','9px').attr('fill','#9CA3AF').text(function(d){ return d.dates||''; });
  _famSim = d3.forceSimulation(nodes)
    .force('link',d3.forceLink(edges).id(function(d){return String(d.id);}).distance(180).strength(0.8))
    .force('charge',d3.forceManyBody().strength(-400))
    .force('center',d3.forceCenter(cx,cy))
    .force('collision',d3.forceCollide(60))
    .on('tick',function(){
      lnk.attr('x1',function(d){return d.source?d.source.x:cx;}).attr('y1',function(d){return d.source?d.source.y:cy;})
         .attr('x2',function(d){return d.target?d.target.x:cx;}).attr('y2',function(d){return d.target?d.target.y:cy;});
      lbl.attr('x',function(d){return d.source&&d.target?(d.source.x+d.target.x)/2:cx;})
         .attr('y',function(d){return d.source&&d.target?(d.source.y+d.target.y)/2-5:cy;});
      ndG.attr('transform',function(d){return 'translate('+(isNaN(d.x)?cx:d.x)+','+(isNaN(d.y)?cy:d.y)+')';});
    });
}
</script>
{% endblock %}
