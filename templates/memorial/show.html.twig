<script>
var _lbItems=[],_lbIdx=0;
function openLightbox(e,el){e.preventDefault();_lbItems=Array.from(document.querySelectorAll('[data-lightbox="gallery"]')).map(function(a){return{url:a.dataset.url,caption:a.dataset.caption,type:a.dataset.type};});_lbIdx=Array.from(document.querySelectorAll('[data-lightbox="gallery"]')).indexOf(el);_showLb(_lbIdx);document.getElementById('lightbox').style.display='flex';}
function closeLightbox(){document.getElementById('lightbox').style.display='none';var v=document.getElementById('lightbox-video');v.pause();v.src='';}
function lightboxNav(d){_lbIdx=(_lbIdx+d+_lbItems.length)%_lbItems.length;_showLb(_lbIdx);}
function _showLb(i){var item=_lbItems[i],img=document.getElementById('lightbox-img'),vid=document.getElementById('lightbox-video');if(item.type==='video'){img.style.display='none';vid.style.display='block';vid.src=item.url;}else{vid.style.display='none';vid.pause();img.style.display='block';img.src=item.url;img.alt=item.caption;}document.getElementById('lightbox-caption').textContent=item.caption||'';document.getElementById('lightbox-counter').textContent=(i+1)+' / '+_lbItems.length;}
document.addEventListener('keydown',function(e){if(document.getElementById('lightbox').style.display==='none')return;if(e.key==='Escape')closeLightbox();if(e.key==='ArrowLeft')lightboxNav(-1);if(e.key==='ArrowRight')lightboxNav(1);});
document.getElementById('lightbox').addEventListener('click',function(e){if(e.target===this)closeLightbox();});

// Gestion galerie modérateur
var MEMORIAL_SLUG_MOD = '{{ page.slug }}';

async function deleteGalleryItem(id) {
  if (!confirm('Supprimer ce média définitivement ?')) return;
  var csrf = document.querySelector(`.mgal-csrf-delete[data-id="${id}"]`)?.textContent?.trim();
  var form = new FormData(); form.append('_token', csrf);
  var resp = await fetch(`/memorial/${MEMORIAL_SLUG_MOD}/media/galerie/${id}/delete`, {method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}});
  var data = await resp.json();
  if (data.success) { document.getElementById(`gallery-item-${id}`)?.remove(); }
  else alert(data.error || 'Erreur');
}

function editGalleryCaption(id, current) {
  var caption = prompt('Modifier la légende :', current);
  if (caption === null) return;
  var csrf = document.querySelector(`.mgal-csrf-caption[data-id="${id}"]`)?.textContent?.trim();
  var form = new FormData(); form.append('_token', csrf); form.append('caption', caption);
  fetch(`/memorial/${MEMORIAL_SLUG_MOD}/media/galerie/${id}/caption`, {method:'POST',body:form,headers:{'X-Requested-With':'XMLHttpRequest'}})
    .then(r => r.json()).then(data => {
      if (data.success) {
        var cap = document.querySelector(`#gallery-item-${id} .memorial-gallery__caption`);
        if (caption) {
          if (cap) cap.textContent = caption;
          else {
            var newCap = document.createElement('div');
            newCap.className = 'memorial-gallery__caption';
            newCap.textContent = caption;
            document.querySelector(`#gallery-item-${id} .memorial-gallery__item`)?.appendChild(newCap);
          }
        } else if (cap) cap.remove();
      }
    });
}

</script>
